<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="VinhThucAudioGuide.MainPage">

    <Grid RowDefinitions="Auto, *, Auto, Auto, Auto" BackgroundColor="#F5F5F5">

        <Grid Grid.Row="0" BackgroundColor="#D32F2F" Padding="15">
            <Label Text="Phố Ẩm Thực Vĩnh Thực" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <mapsui:MapView x:Name="mapView" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" IsMyLocationButtonVisible="False" />
            <Frame WidthRequest="50" HeightRequest="50" CornerRadius="25" Padding="0" Margin="15" HorizontalOptions="End" VerticalOptions="End" BackgroundColor="White" HasShadow="True" BorderColor="LightGray">
                <Button Text="🎯" FontSize="22" BackgroundColor="Transparent" Clicked="MyLocation_Clicked"/>
            </Frame>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*, *, *" Padding="10,10,10,5" BackgroundColor="White">
            <Button Grid.Column="0" Text="🏕️ Du lịch" BackgroundColor="#E3F2FD" TextColor="#1565C0" Margin="5" FontAttributes="Bold" CornerRadius="8" Clicked="Category_Clicked"/>
            <Button Grid.Column="1" Text="🍜 Ẩm thực" BackgroundColor="#FFF3E0" TextColor="#E65100" Margin="5" FontAttributes="Bold" CornerRadius="8" Clicked="Category_Clicked"/>
            <Button Grid.Column="2" Text="🎉 Sự kiện" BackgroundColor="#F3E5F5" TextColor="#4A148C" Margin="5" FontAttributes="Bold" CornerRadius="8" Clicked="Category_Clicked"/>
        </Grid>

        <CollectionView Grid.Row="3" x:Name="cvPoiList" HeightRequest="100" SelectionMode="Single" SelectionChanged="Poi_Selected" BackgroundColor="White">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15" Margin="10,5" CornerRadius="10" BackgroundColor="#FAFAFA" BorderColor="LightGray" WidthRequest="220">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="Black" FontSize="14" LineBreakMode="TailTruncation"/>
                            <Label Text="Nhấn để xem trên map" FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Frame Grid.Row="4" CornerRadius="15" Margin="10" Padding="15" BackgroundColor="White" HasShadow="True" BorderColor="LightGray">
            <VerticalStackLayout Spacing="5">
                <Label x:Name="lblPoiName" Text="Vui lòng chọn danh mục" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                <Label x:Name="lblDistance" Text="" FontSize="14" TextColor="#E65100" FontAttributes="Italic" />

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,10,0,0">
                    <Button Text="🧭 Chỉ đường" BackgroundColor="#4CAF50" TextColor="White" HeightRequest="40" Padding="10,5" Clicked="Navigate_Clicked"/>
                    <Button Text="🔊 Nghe thuyết minh" BackgroundColor="#2196F3" TextColor="White" HeightRequest="40" Padding="10,5" Clicked="Speak_Clicked"/>
                    <Button Text="⏹️ Dừng" BackgroundColor="#F44336" TextColor="White" HeightRequest="40" Padding="10,5" Clicked="StopSpeech_Clicked"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>