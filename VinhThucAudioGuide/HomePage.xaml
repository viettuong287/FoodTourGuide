<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhThucAudioGuide.HomePage"
             Title="Trang chủ"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="3*, Auto, Auto, Auto, 2*, Auto" Padding="25">
        <Image Grid.Row="0" Source="travel_header.jpg" HeightRequest="200" VerticalOptions="Center" HorizontalOptions="Center" Aspect="AspectFill" />

        <Label x:Name="LblTitle" Grid.Row="1" Text="Vĩnh Thực Audio Guide" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#0055CC"/>
        <Label x:Name="LblDesc" Grid.Row="2" Text="Khám phá vẻ đẹp biển đảo qua từng câu chuyện kể tự động." 
               HorizontalTextAlignment="Center" FontSize="16" TextColor="#4A4A4A" Margin="0,15,0,0" LineHeight="1.3"/>
        <Label Grid.Row="3" Text="v1.0.0" FontSize="13" HorizontalOptions="Center" TextColor="Gray" Margin="0,10,0,0"/>

        <Button Grid.Row="5" x:Name="BtnStart" Text="BẮT ĐẦU HÀNH TRÌNH" BackgroundColor="#0055CC" TextColor="White" 
                FontAttributes="Bold" CornerRadius="15" HeightRequest="55" Margin="0,0,0,20"
                Clicked="BtnGoToMap_Clicked"/>
    </Grid>
</ContentPage>