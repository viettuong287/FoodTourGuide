@model Web.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Market Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1e2d40; --navy-mid: #2c3e55; --cream: #f7f3ed; --ivory: #faf8f4;
            --gold: #b8964e; --gold-light: #d4ae6a; --text-dark: #1e2d40;
            --text-mid: #4a5568; --text-light: #718096; --border: #d9cfc2;
            --radius: 12px; --radius-sm: 6px; --shadow-lg: 0 12px 40px rgba(30,45,64,0.16);
        }
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #1a3a2a 100%); font-family: 'Source Sans 3', sans-serif; font-size: 15px; color: var(--text-dark); }
        .auth-shell { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 32px 16px; position: relative; overflow: hidden; }
        .auth-shell::before { content: ''; position: absolute; top: -80px; right: -80px; width: 320px; height: 320px; border-radius: 50%; background: rgba(184,150,78,0.07); pointer-events: none; }
        .auth-shell::after { content: ''; position: absolute; bottom: -60px; left: -60px; width: 240px; height: 240px; border-radius: 50%; background: rgba(184,150,78,0.05); pointer-events: none; }
        .auth-card { background: var(--ivory); border-radius: var(--radius); box-shadow: var(--shadow-lg); width: 100%; max-width: 440px; overflow: hidden; position: relative; z-index: 1; animation: fadeUp 0.4s ease both; }
        @@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .auth-header { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%); padding: 36px 40px 28px; text-align: center; }
        .auth-brand { display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; background: linear-gradient(135deg, var(--gold), var(--gold-light)); border-radius: 12px; margin-bottom: 16px; }
        .auth-brand i { font-size: 26px; color: var(--navy); }
        .auth-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 700; color: var(--cream); margin: 0 0 6px; }
        .auth-subtitle { font-size: 13px; color: rgba(247,243,237,0.65); margin: 0; }
        .auth-body { padding: 32px 40px 36px; }
        .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px; display: block; letter-spacing: 0.01em; }
        .form-control { width: 100%; border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 14px; font-size: 14px; color: var(--text-dark); background: #fff; transition: all 0.2s ease; outline: none; }
        .form-control:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.12); }
        .form-control.is-invalid { border-color: #a2493a; }
        .input-group { position: relative; }
        .input-group .form-control { padding-right: 42px; }
        .input-group-icon { position: absolute; right: 13px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 16px; cursor: pointer; user-select: none; }
        .input-group-icon:hover { color: var(--gold); }
        .btn-submit { width: 100%; background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: var(--navy); border: none; border-radius: var(--radius-sm); padding: 12px; font-size: 14.5px; font-weight: 700; letter-spacing: 0.03em; cursor: pointer; transition: all 0.2s ease; box-shadow: 0 2px 12px rgba(184,150,78,0.3); display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-submit:hover { box-shadow: 0 4px 18px rgba(184,150,78,0.45); transform: translateY(-1px); }
        .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
        .auth-divider { text-align: center; margin: 22px 0; position: relative; }
        .auth-divider::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: var(--border); }
        .auth-divider span { background: var(--ivory); padding: 0 12px; position: relative; font-size: 12px; color: var(--text-light); }
        .auth-link-text { text-align: center; font-size: 13.5px; color: var(--text-mid); margin: 0; }
        .auth-link-text a { color: var(--gold); text-decoration: none; font-weight: 600; }
        .auth-link-text a:hover { text-decoration: underline; }
        .alert-auth { background: rgba(162,73,58,0.08); border: 1px solid rgba(162,73,58,0.2); border-radius: var(--radius-sm); color: #a2493a; padding: 11px 14px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: flex-start; gap: 8px; }
        .alert-success-auth { background: rgba(74,124,89,0.08); border: 1px solid rgba(74,124,89,0.2); border-radius: var(--radius-sm); color: #3a7d4f; padding: 11px 14px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: flex-start; gap: 8px; }
        .invalid-msg { color: #a2493a; font-size: 12px; margin-top: 4px; display: block; }
        .field-mb { margin-bottom: 18px; }
        .form-check { display: flex; align-items: center; gap: 8px; }
        .form-check-label { font-size: 13px; color: var(--text-mid); cursor: pointer; }
        .validation-summary-valid { display: none !important; }
    </style>
</head>
<body>
<div class="auth-shell">
    <div class="auth-card">

        <div class="auth-header">
            <div class="auth-brand"><i class="bi bi-shop"></i></div>
            <h1 class="auth-title">Welcome Back</h1>
            <p class="auth-subtitle">Sign in to Market Management System</p>
        </div>

        <div class="auth-body">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-success-auth">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["SuccessMessage"]</span>
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="alert-auth">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span></span>
            </div>

            <form asp-action="Login" asp-controller="Auth" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="field-mb">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email"
                           class="form-control @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           type="email" placeholder="you@example.com"
                           autocomplete="email" autofocus />
                    <span asp-validation-for="Email" class="invalid-msg"></span>
                </div>

                <div class="field-mb">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group">
                        <input asp-for="Password"
                               class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="password" id="passwordInput"
                               placeholder="Enter your password"
                               autocomplete="current-password" />
                        <i class="bi bi-eye-slash input-group-icon" id="togglePassword"></i>
                    </div>
                    <span asp-validation-for="Password" class="invalid-msg"></span>
                </div>

                <div class="field-mb">
                    <label class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                        <span class="form-check-label">Remember me on this device</span>
                    </label>
                </div>

                <div style="margin-bottom: 24px;">
                    <button type="submit" class="btn-submit" id="btnLogin">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </button>
                </div>
            </form>

            <div class="auth-divider"><span>or</span></div>

            <p class="auth-link-text">
                Don't have an account?
                <a asp-controller="Auth" asp-action="Register">Create one</a>
            </p>

        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />
<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        const input = document.getElementById('passwordInput');
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        this.className = isPassword ? 'bi bi-eye input-group-icon' : 'bi bi-eye-slash input-group-icon';
    });

    document.querySelector('form').addEventListener('submit', function () {
        const btn = document.getElementById('btnLogin');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Signing in...';
    });
</script>
</body>
</html>
