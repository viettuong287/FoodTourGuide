@model Web.Models.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Create Account";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Market Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1e2d40; --navy-mid: #2c3e55; --cream: #f7f3ed; --ivory: #faf8f4;
            --gold: #b8964e; --gold-light: #d4ae6a; --border: #d9cfc2;
            --text-dark: #1e2d40; --text-mid: #4a5568; --text-light: #718096;
            --radius: 12px; --radius-sm: 6px; --shadow-lg: 0 12px 40px rgba(30,45,64,0.16);
        }
        *, *::before, *::after { box-sizing: border-box; }
        html, body { min-height: 100%; margin: 0; background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #1a3a2a 100%); font-family: 'Source Sans 3', sans-serif; font-size: 15px; color: var(--text-dark); }
        .auth-shell { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 32px 16px; position: relative; overflow: hidden; }
        .auth-shell::before { content: ''; position: absolute; top: -80px; right: -80px; width: 320px; height: 320px; border-radius: 50%; background: rgba(184,150,78,0.07); pointer-events: none; }
        .auth-card { background: var(--ivory); border-radius: var(--radius); box-shadow: var(--shadow-lg); width: 100%; max-width: 480px; overflow: hidden; position: relative; z-index: 1; animation: fadeUp 0.4s ease both; }
        @@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .auth-header { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%); padding: 32px 40px 24px; text-align: center; }
        .auth-brand { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; background: linear-gradient(135deg, var(--gold), var(--gold-light)); border-radius: 11px; margin-bottom: 14px; }
        .auth-brand i { font-size: 24px; color: var(--navy); }
        .auth-title { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--cream); margin: 0 0 5px; }
        .auth-subtitle { font-size: 13px; color: rgba(247,243,237,0.65); margin: 0; }
        .auth-body { padding: 28px 40px 32px; }
        .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 5px; display: block; }
        .form-control { width: 100%; border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 9px 13px; font-size: 14px; color: var(--text-dark); background: #fff; transition: all 0.2s ease; outline: none; }
        .form-control:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.12); }
        .form-control.is-invalid { border-color: #a2493a; }
        .input-group { position: relative; }
        .input-group .form-control { padding-right: 40px; }
        .input-group-icon { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 15px; cursor: pointer; user-select: none; }
        .input-group-icon:hover { color: var(--gold); }
        .btn-submit { width: 100%; background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: var(--navy); border: none; border-radius: var(--radius-sm); padding: 11px; font-size: 14.5px; font-weight: 700; letter-spacing: 0.03em; cursor: pointer; transition: all 0.2s ease; box-shadow: 0 2px 12px rgba(184,150,78,0.3); display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-submit:hover { box-shadow: 0 4px 18px rgba(184,150,78,0.45); transform: translateY(-1px); }
        .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
        .auth-divider { text-align: center; margin: 20px 0; position: relative; }
        .auth-divider::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: var(--border); }
        .auth-divider span { background: var(--ivory); padding: 0 12px; position: relative; font-size: 12px; color: var(--text-light); }
        .auth-link-text { text-align: center; font-size: 13.5px; color: var(--text-mid); margin: 0; }
        .auth-link-text a { color: var(--gold); text-decoration: none; font-weight: 600; }
        .auth-link-text a:hover { text-decoration: underline; }
        .alert-auth { background: rgba(162,73,58,0.08); border: 1px solid rgba(162,73,58,0.2); border-radius: var(--radius-sm); color: #a2493a; padding: 10px 13px; font-size: 13px; margin-bottom: 18px; display: flex; align-items: flex-start; gap: 8px; }
        .invalid-msg { color: #a2493a; font-size: 12px; margin-top: 4px; display: block; }
        .field-mb { margin-bottom: 15px; }
        .strength-bar { height: 4px; border-radius: 2px; background: #e9ecef; margin-top: 6px; overflow: hidden; }
        .strength-fill { height: 100%; width: 0; transition: all 0.3s ease; border-radius: 2px; }
        .hint-text { font-size: 11.5px; color: var(--text-light); margin-top: 4px; }
        @@media (max-width: 480px) { .auth-body { padding: 24px 24px 28px; } .auth-header { padding: 24px 24px 20px; } .row-2 { grid-template-columns: 1fr; } }
        .validation-summary-valid { display: none !important; }
    </style>
</head>
<body>
<div class="auth-shell">
    <div class="auth-card">

        <div class="auth-header">
            <div class="auth-brand"><i class="bi bi-person-plus"></i></div>
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle">Register as a Business Owner</p>
        </div>

        <div class="auth-body">

            <div asp-validation-summary="ModelOnly" class="alert-auth">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span></span>
            </div>

            <form asp-action="Register" asp-controller="Auth" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="row-2">
                    <div class="field-mb">
                        <label asp-for="UserName" class="form-label">Username <span style="color:#a2493a">*</span></label>
                        <input asp-for="UserName"
                               class="form-control @(ViewData.ModelState["UserName"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="your_username" autocomplete="username" autofocus />
                        <span asp-validation-for="UserName" class="invalid-msg"></span>
                    </div>
                    <div class="field-mb">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number <span style="color:#a2493a">*</span></label>
                        <input asp-for="PhoneNumber"
                               class="form-control @(ViewData.ModelState["PhoneNumber"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               type="tel" placeholder="+84 123 456 789" autocomplete="tel" />
                        <span asp-validation-for="PhoneNumber" class="invalid-msg"></span>
                    </div>
                </div>

                <div class="field-mb">
                    <label asp-for="Email" class="form-label">Email Address <span style="color:#a2493a">*</span></label>
                    <input asp-for="Email"
                           class="form-control @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                           type="email" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="invalid-msg"></span>
                </div>

                <div class="row-2">
                    <div class="field-mb">
                        <label asp-for="Password" class="form-label">Password <span style="color:#a2493a">*</span></label>
                        <div class="input-group">
                            <input asp-for="Password"
                                   class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   type="password" id="passwordInput"
                                   placeholder="Min. 6 characters" autocomplete="new-password" />
                            <i class="bi bi-eye-slash input-group-icon" id="togglePassword"></i>
                        </div>
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <div class="hint-text" id="strengthText"></div>
                        <span asp-validation-for="Password" class="invalid-msg"></span>
                    </div>
                    <div class="field-mb">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span style="color:#a2493a">*</span></label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword"
                                   class="form-control @(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                   type="password" id="confirmInput"
                                   placeholder="Repeat password" autocomplete="new-password" />
                            <i class="bi bi-eye-slash input-group-icon" id="toggleConfirm"></i>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="invalid-msg"></span>
                    </div>
                </div>

                <div style="margin-top: 6px; margin-bottom: 24px;">
                    <button type="submit" class="btn-submit" id="btnRegister">
                        <i class="bi bi-person-check"></i> Create Account
                    </button>
                </div>
            </form>

            <div class="auth-divider"><span>or</span></div>

            <p class="auth-link-text">
                Already have an account?
                <a asp-controller="Auth" asp-action="Login">Sign in</a>
            </p>

        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />
<script>
    function togglePwd(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        icon.className = (isPassword ? 'bi bi-eye' : 'bi bi-eye-slash') + ' input-group-icon';
    }

    document.getElementById('togglePassword').addEventListener('click', function () { togglePwd('passwordInput', 'togglePassword'); });
    document.getElementById('toggleConfirm').addEventListener('click', function () { togglePwd('confirmInput', 'toggleConfirm'); });

    // Password strength indicator
    document.getElementById('passwordInput').addEventListener('input', function () {
        var pw = this.value;
        var fill = document.getElementById('strengthFill');
        var text = document.getElementById('strengthText');
        var strength = 0;
        if (pw.length >= 6) strength++;
        if (/[A-Z]/.test(pw)) strength++;
        if (/[a-z]/.test(pw)) strength++;
        if (/[0-9]/.test(pw)) strength++;

        if (pw.length === 0) {
            fill.style.width = '0'; fill.style.background = ''; text.textContent = '';
        } else if (strength <= 2) {
            fill.style.width = '33%'; fill.style.background = '#a2493a'; text.textContent = 'Weak password'; text.style.color = '#a2493a';
        } else if (strength === 3) {
            fill.style.width = '66%'; fill.style.background = '#d4ae6a'; text.textContent = 'Medium password'; text.style.color = '#b8964e';
        } else {
            fill.style.width = '100%'; fill.style.background = '#3a7d4f'; text.textContent = 'Strong password'; text.style.color = '#3a7d4f';
        }
    });

    document.querySelector('form').addEventListener('submit', function () {
        const btn = document.getElementById('btnRegister');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Creating account...';
    });
</script>
</body>
</html>
