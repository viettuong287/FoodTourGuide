@model Web.Models.UserRoleManagementViewModel
@{
    ViewData["Title"] = "User & Role Management";
    var totalPages = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize) : 1;
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex   = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);

    // Preserve filter params for pagination
    var filterRoute = new Dictionary<string, string?> {
        ["pageSize"]      = Model.PageSize.ToString(),
        ["search"]        = Model.Search,
        ["roleFilter"]    = Model.RoleFilter,
        ["isActiveFilter"] = Model.IsActiveFilter?.ToString()
    };
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed; --cream-dark: #ede8df; --ivory: #faf8f4;
        --navy: #1e2d40; --navy-mid: #2c3e55; --navy-light: #3d5068;
        --gold: #b8964e; --gold-light: #d4ae6a; --gold-pale: #f0e4c8;
        --text-dark: #1e2d40; --text-mid: #4a5568; --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --shadow-lg: 0 8px 32px rgba(30,45,64,0.13);
        --radius: 10px; --radius-sm: 6px;
    }

    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

    /* Page header */
    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius); padding: 32px 40px; margin-bottom: 28px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 20px; box-shadow: var(--shadow-md);
        position: relative; overflow: hidden;
    }
    .page-header::before { content: ''; position: absolute; top: -20px; right: -20px; width: 160px; height: 160px; border-radius: 50%; background: rgba(184,150,78,0.08); pointer-events: none; }
    .page-header-content { position: relative; z-index: 1; }
    .page-header h1 { font-size: 2rem; font-weight: 700; color: var(--cream); margin: 0 0 8px; display: flex; align-items: center; gap: 12px; }
    .page-header h1 i { color: var(--gold-light); }
    .page-header .lead { font-size: 14px; color: rgba(247,243,237,0.7); margin: 0; }
    .page-header-actions { position: relative; z-index: 1; }
    .btn-gold { background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: var(--navy); border: none; font-weight: 600; font-size: 13.5px; padding: 10px 22px; border-radius: var(--radius-sm); box-shadow: 0 2px 10px rgba(184,150,78,0.3); display: inline-flex; align-items: center; gap: 7px; cursor: pointer; transition: all 0.2s; }
    .btn-gold:hover { box-shadow: 0 4px 16px rgba(184,150,78,0.4); transform: translateY(-1px); color: var(--navy); }

    /* Role stats */
    .roles-strip { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 24px; }
    .role-chip { display: inline-flex; align-items: center; gap: 8px; background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 9px 16px; font-size: 13px; box-shadow: var(--shadow-sm); transition: all 0.2s; cursor: pointer; text-decoration: none; }
    .role-chip:hover { border-color: var(--gold); background: var(--gold-pale); color: var(--navy); }
    .role-chip.active-filter { border-color: var(--gold); background: var(--gold-pale); }
    .role-chip-name { font-weight: 600; color: var(--text-dark); }
    .role-chip-count { font-size: 12px; background: var(--cream-dark); color: var(--text-light); padding: 1px 7px; border-radius: 10px; font-weight: 600; }

    /* Filter */
    .filter-card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); padding: 20px 24px; margin-bottom: 24px; }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px; }
    .form-control, .form-select { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 8px 13px; font-size: 13.5px; color: var(--text-dark); background: #fff; transition: all 0.2s; }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.1); outline: none; }
    .search-box { position: relative; }
    .search-box .si { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 14px; pointer-events: none; }
    .search-box .form-control { padding-left: 38px; }
    .btn-classic { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 600; padding: 7px 14px; border-radius: var(--radius-sm); border: 1.5px solid; text-decoration: none; transition: all 0.18s; background: transparent; white-space: nowrap; cursor: pointer; }
    .btn-classic.navy { border-color: var(--navy); color: var(--navy); }
    .btn-classic.navy:hover { background: var(--navy); color: var(--cream); }

    /* Table */
    .table-card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); }
    .table-card-header { background: var(--cream-dark); border-bottom: 1px solid var(--border); padding: 14px 24px; display: flex; justify-content: space-between; align-items: center; border-radius: var(--radius) var(--radius) 0 0; font-size: 13.5px; }
    .table-card-footer { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 14px 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; border-radius: 0 0 var(--radius) var(--radius); }
    .table { margin: 0; font-size: 13.5px; }
    .table thead { background: var(--cream-dark); }
    .table thead th { font-size: 11.5px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); border-bottom: 2px solid var(--border); padding: 12px 16px; white-space: nowrap; }
    .table tbody td { padding: 13px 16px; vertical-align: middle; border-bottom: 1px solid var(--border); }
    .table tbody tr { background: #fff; transition: background 0.15s; }
    .table tbody tr:hover { background: var(--cream); }
    .table tbody tr:last-child td { border-bottom: none; }

    /* User avatar */
    .user-avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, var(--navy-mid), var(--navy-light)); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .user-avatar span { font-size: 13px; font-weight: 700; color: #fff; line-height: 1; }
    .user-name { font-weight: 600; font-size: 13.5px; color: var(--text-dark); }
    .user-email { font-size: 12px; color: var(--text-light); }

    /* Role badges */
    .role-badge { font-size: 11.5px; font-weight: 600; padding: 3px 10px; border-radius: 20px; border: 1px solid; white-space: nowrap; display: inline-block; margin: 1px 2px; }
    .role-admin   { background: rgba(107,76,154,0.10); color: #6b4c9a; border-color: rgba(107,76,154,0.28); }
    .role-owner   { background: rgba(184,150,78,0.12); color: #7a5c1e; border-color: rgba(184,150,78,0.30); }
    .role-visitor { background: rgba(30,45,64,0.08);   color: var(--navy); border-color: rgba(30,45,64,0.18); }
    .role-default { background: rgba(113,128,150,0.09); color: #5c6b7c; border-color: rgba(113,128,150,0.22); }

    /* Status badges */
    .badge-active   { background: rgba(58,125,79,0.10);  color: #3a7d4f; border: 1px solid rgba(58,125,79,0.25);  padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-inactive { background: rgba(162,73,58,0.09);  color: #a2493a; border: 1px solid rgba(162,73,58,0.22); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }

    /* Date */
    .date-main { font-size: 13px; color: var(--text-dark); }
    .date-sub  { font-size: 11.5px; color: var(--text-light); }
    .never     { font-size: 12.5px; color: var(--text-light); font-style: italic; }

    /* Inline role select */
    .role-select-form { display: flex; align-items: center; gap: 6px; }
    .role-select-form .form-select { font-size: 12.5px; padding: 4px 10px; min-width: 120px; border-radius: var(--radius-sm); }
    .btn-apply { font-size: 12px; padding: 4px 10px; border-radius: var(--radius-sm); border: 1.5px solid var(--gold); background: transparent; color: var(--gold); font-weight: 600; cursor: pointer; transition: all 0.18s; white-space: nowrap; }
    .btn-apply:hover { background: var(--gold); color: var(--navy); }

    /* Toggle active button */
    .btn-toggle-active { font-size: 12px; padding: 4px 10px; border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: all 0.18s; border: 1.5px solid; white-space: nowrap; background: transparent; }
    .btn-toggle-active.deactivate { border-color: #a2493a; color: #a2493a; }
    .btn-toggle-active.deactivate:hover { background: #a2493a; color: #fff; }
    .btn-toggle-active.activate { border-color: #3a7d4f; color: #3a7d4f; }
    .btn-toggle-active.activate:hover { background: #3a7d4f; color: #fff; }

    /* Pagination */
    .pagination { gap: 4px; }
    .pagination .page-link { border: 1px solid var(--border); color: var(--text-dark); padding: 6px 12px; font-size: 13px; border-radius: var(--radius-sm); transition: all 0.18s; }
    .pagination .page-link:hover { background: var(--gold-pale); border-color: var(--gold); color: var(--navy); }
    .pagination .page-item.active .page-link { background: var(--gold); border-color: var(--gold); color: var(--navy); font-weight: 600; }
    .pagination .page-item.disabled .page-link { background: var(--cream); border-color: var(--border); color: var(--text-light); pointer-events: none; }

    /* Modal */
    .modal-content { border: none; border-radius: var(--radius); box-shadow: var(--shadow-lg); }
    .modal-header { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%); border-bottom: none; border-radius: var(--radius) var(--radius) 0 0; padding: 20px 24px; }
    .modal-header .modal-title { font-size: 17px; font-weight: 700; color: var(--cream); display: flex; align-items: center; gap: 10px; }
    .modal-header .modal-title i { color: var(--gold-light); }
    .modal-header .btn-close { filter: brightness(0) invert(1); opacity: 0.7; }
    .modal-header .btn-close:hover { opacity: 1; }
    .modal-body { padding: 26px 24px; background: var(--ivory); }
    .modal-footer { background: var(--cream-dark); border-top: 1px solid var(--border); border-radius: 0 0 var(--radius) var(--radius); padding: 14px 24px; }
    .input-group-text { background: var(--cream-dark); border: 1px solid var(--border); color: var(--text-light); border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
    .input-group .form-control { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }

    /* Empty */
    .empty-state { text-align: center; padding: 56px 20px; color: var(--text-light); }
    .empty-state i { font-size: 44px; margin-bottom: 12px; display: block; opacity: 0.45; }
    .empty-state p { font-size: 13.5px; margin: 0; }

    .validation-summary-valid { display: none !important; }
    .text-danger { color: #a2493a !important; }

    @@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.4s ease 0.05s both; }
    .anim-2 { animation: fadeUp 0.4s ease 0.10s both; }
    .anim-3 { animation: fadeUp 0.4s ease 0.15s both; }
    .anim-4 { animation: fadeUp 0.4s ease 0.20s both; }

    @@media (max-width: 576px) {
        .page-header { padding: 24px 20px; }
        .page-header h1 { font-size: 1.5rem; }
        .page-header-actions { width: 100%; }
        .role-select-form { flex-wrap: wrap; }
    }
</style>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Dashboard">Admin</a></li>
        <li class="breadcrumb-item active" aria-current="page">User & Role Management</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header anim-1">
    <div class="page-header-content">
        <h1><i class="bi bi-people"></i>User & Role Management</h1>
        <p class="lead">Quản lý tài khoản và phân quyền người dùng trong hệ thống.</p>
    </div>
    <div class="page-header-actions">
        <button type="button" class="btn-gold" data-bs-toggle="modal" data-bs-target="#createUserModal">
            <i class="bi bi-person-plus"></i>Tạo user mới
        </button>
    </div>
</div>

<!-- Alerts -->
@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show anim-1" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show anim-1" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Role chips -->
@if (Model.Roles.Count > 0)
{
    <div class="roles-strip anim-2">
        <a asp-action="UserRoleManagement"
           asp-all-route-data="@(new Dictionary<string,string?> { ["page"]="1", ["pageSize"]=Model.PageSize.ToString(), ["search"]=Model.Search })"
           class="role-chip @(Model.RoleFilter == null ? "active-filter" : "")">
            <i class="bi bi-people" style="color:var(--text-light);font-size:15px;"></i>
            <span class="role-chip-name">Tất cả</span>
            <span class="role-chip-count">@Model.TotalCount</span>
        </a>
        @foreach (var role in Model.Roles)
        {
            var rIcon = role.Name switch {
                "Admin"         => "bi-shield-lock",
                "BusinessOwner" => "bi-building",
                "Visitor"       => "bi-person",
                _               => "bi-person-badge"
            };
            <a asp-action="UserRoleManagement"
               asp-all-route-data="@(new Dictionary<string,string?> { ["page"]="1", ["pageSize"]=Model.PageSize.ToString(), ["search"]=Model.Search, ["roleFilter"]=role.Name })"
               class="role-chip @(Model.RoleFilter == role.Name ? "active-filter" : "")">
                <i class="bi @rIcon" style="color:var(--text-light);font-size:15px;"></i>
                <span class="role-chip-name">@role.Name</span>
                <span class="role-chip-count">@role.UserCount</span>
            </a>
        }
    </div>
}

<!-- Filter -->
<div class="filter-card anim-3">
    <form method="get" asp-action="UserRoleManagement" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Tìm kiếm</label>
            <div class="search-box">
                <i class="bi bi-search si"></i>
                <input type="text" class="form-control" name="search"
                       value="@Model.Search" placeholder="Tên đăng nhập hoặc email...">
            </div>
        </div>
        <div class="col-md-2">
            <label class="form-label">Role</label>
            <select name="roleFilter" class="form-select">
                <option value="">— Tất cả —</option>
                @foreach (var r in Model.Roles)
                {
                    <option value="@r.Name" selected="@(Model.RoleFilter == r.Name ? "selected" : null)">@r.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Trạng thái</label>
            <select name="isActiveFilter" class="form-select">
                <option value="">— Tất cả —</option>
                <option value="True"  selected="@(Model.IsActiveFilter == true  ? "selected" : null)">Active</option>
                <option value="False" selected="@(Model.IsActiveFilter == false ? "selected" : null)">Inactive</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Số dòng / trang</label>
            <select name="pageSize" class="form-select">
                @foreach (var s in new[] { 10, 20, 50 })
                {
                    <option value="@s" selected="@(Model.PageSize == s ? "selected" : null)">@s</option>
                }
            </select>
        </div>
        <div class="col-auto d-flex gap-2 align-items-end">
            <button type="submit" class="btn-classic navy"><i class="bi bi-funnel"></i>Lọc</button>
            <a asp-action="UserRoleManagement" class="btn-classic navy"><i class="bi bi-x-circle"></i>Xoá lọc</a>
        </div>
    </form>
</div>

<!-- Table -->
<div class="table-card anim-4">
    <div class="table-card-header">
        <span>
            <strong>@Model.TotalCount</strong> tài khoản
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <span class="text-muted" style="font-size:12.5px;"> — tìm "<em>@Model.Search</em>"</span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.RoleFilter))
            {
                <span class="text-muted" style="font-size:12.5px;"> · role <strong>@Model.RoleFilter</strong></span>
            }
        </span>
        <span style="font-size:12.5px;color:var(--text-light);">
            @startIndex–@endIndex / @Model.TotalCount
        </span>
    </div>

    <div class="table-responsive">
        <table class="table" aria-label="User list">
            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Role hiện tại</th>
                    <th>Đổi role</th>
                    <th>Trạng thái</th>
                    <th>Đăng nhập lần cuối</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-people"></i>
                                <p>Không tìm thấy tài khoản nào.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var u in Model.Users)
                    {
                        var initial = (u.UserName ?? u.Email ?? "?")[0].ToString().ToUpper();
                        var primaryRole = u.Roles.FirstOrDefault() ?? "";

                        <tr>
                            <!-- User info -->
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar"><span>@initial</span></div>
                                    <div>
                                        <div class="user-name">@(u.UserName ?? "—")</div>
                                        <div class="user-email">@(u.Email ?? "—")</div>
                                    </div>
                                </div>
                            </td>

                            <!-- Current roles -->
                            <td>
                                @if (u.Roles.Count == 0)
                                {
                                    <span style="color:var(--text-light);font-size:12.5px;font-style:italic;">Chưa có role</span>
                                }
                                else
                                {
                                    foreach (var r in u.Roles)
                                    {
                                        var rCls = r switch {
                                            "Admin"         => "role-admin",
                                            "BusinessOwner" => "role-owner",
                                            "Visitor"       => "role-visitor",
                                            _               => "role-default"
                                        };
                                        <span class="role-badge @rCls">@r</span>
                                    }
                                }
                            </td>

                            <!-- Change role inline -->
                            <td>
                                <form asp-action="UpdateUserRole" method="post" class="role-select-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id"           value="@u.Id" />
                                    <input type="hidden" name="page"         value="@Model.Page" />
                                    <input type="hidden" name="pageSize"     value="@Model.PageSize" />
                                    <input type="hidden" name="search"       value="@Model.Search" />
                                    <input type="hidden" name="roleFilter"   value="@Model.RoleFilter" />
                                    <input type="hidden" name="isActiveFilter" value="@Model.IsActiveFilter" />
                                    <select name="roleName" class="form-select">
                                        @foreach (var r in Model.Roles)
                                        {
                                            <option value="@r.Name" selected="@(primaryRole == r.Name ? "selected" : null)">@r.Name</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn-apply">
                                        <i class="bi bi-check2"></i>Áp dụng
                                    </button>
                                </form>
                            </td>

                            <!-- Status -->
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge-inactive">Inactive</span>
                                }
                            </td>

                            <!-- Last login -->
                            <td>
                                @if (u.LastLoginAt.HasValue)
                                {
                                    <div class="date-main">@u.LastLoginAt.Value.ToString("dd/MM/yyyy")</div>
                                    <div class="date-sub">@u.LastLoginAt.Value.ToString("HH:mm")</div>
                                }
                                else
                                {
                                    <span class="never">Chưa đăng nhập</span>
                                }
                            </td>

                            <!-- Created at -->
                            <td>
                                <div class="date-main">@u.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <div class="date-sub">@u.CreatedAt.ToString("HH:mm")</div>
                            </td>

                            <!-- Toggle active -->
                            <td class="text-end">
                                <form asp-action="ToggleUserActive" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id"             value="@u.Id" />
                                    <input type="hidden" name="page"           value="@Model.Page" />
                                    <input type="hidden" name="pageSize"       value="@Model.PageSize" />
                                    <input type="hidden" name="search"         value="@Model.Search" />
                                    <input type="hidden" name="roleFilter"     value="@Model.RoleFilter" />
                                    <input type="hidden" name="isActiveFilter" value="@Model.IsActiveFilter" />
                                    <button type="submit"
                                            class="btn-toggle-active @(u.IsActive ? "deactivate" : "activate")"
                                            onclick="return confirm('@(u.IsActive ? "Vô hiệu hoá" : "Kích hoạt") tài khoản \"@u.UserName\"?')">
                                        @if (u.IsActive)
                                        {
                                            <i class="bi bi-person-x"></i><text> Vô hiệu hoá</text>
                                        }
                                        else
                                        {
                                            <i class="bi bi-person-check"></i><text> Kích hoạt</text>
                                        }
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="table-card-footer">
            <span style="font-size:13px;color:var(--text-light);">
                Trang @Model.Page / @totalPages
            </span>
            <nav aria-label="User pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="UserRoleManagement"
                           asp-route-page="@(Model.Page - 1)"
                           asp-all-route-data="@filterRoute">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(totalPages, Model.Page + 2); p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link"
                               asp-action="UserRoleManagement"
                               asp-route-page="@p"
                               asp-all-route-data="@filterRoute">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= totalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="UserRoleManagement"
                           asp-route-page="@(Model.Page + 1)"
                           asp-all-route-data="@filterRoute">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createUserModalLabel">
                    <i class="bi bi-person-plus"></i>Tạo tài khoản mới
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AdminCreateUser" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Tên đăng nhập <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input type="text" name="UserName" class="form-control"
                                       placeholder="username" required maxlength="100">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" name="Email" class="form-control"
                                       placeholder="user@example.com" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input type="password" name="Password" id="createPassword"
                                       class="form-control" placeholder="Tối thiểu 6 ký tự" required minlength="6">
                                <button type="button" class="btn btn-outline-secondary"
                                        style="border-radius:0 var(--radius-sm) var(--radius-sm) 0;"
                                        onclick="togglePwd('createPassword', this)">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                <input type="tel" name="PhoneNumber" class="form-control"
                                       placeholder="+84 xxx xxx xxx" maxlength="20">
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Role <span class="text-danger">*</span></label>
                            <select name="RoleName" class="form-select" required>
                                <option value="">— Chọn role —</option>
                                @foreach (var r in Model.Roles)
                                {
                                    <option value="@r.Name">@r.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                    <button type="submit" class="btn-gold">
                        <i class="bi bi-person-check"></i>Tạo tài khoản
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function togglePwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon  = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }
</script>
}
