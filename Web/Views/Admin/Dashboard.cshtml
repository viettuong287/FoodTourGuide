@model Web.Models.AdminDashboardViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Admin Dashboard";
    var apiBase = (Configuration["Api:BaseUrl"] ?? "https://localhost:7188/").TrimEnd('/');
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed; --cream-dark: #ede8df; --ivory: #faf8f4;
        --navy: #1e2d40; --navy-mid: #2c3e55; --navy-light: #3d5068;
        --gold: #b8964e; --gold-light: #d4ae6a; --gold-pale: #f0e4c8;
        --text-dark: #1e2d40; --text-mid: #4a5568; --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --shadow-lg: 0 8px 32px rgba(30,45,64,0.13);
        --radius: 10px; --radius-sm: 6px;
    }

    /* Breadcrumb */
    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius); padding: 32px 40px; margin-bottom: 28px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 20px; box-shadow: var(--shadow-md);
        position: relative; overflow: hidden;
    }
    .page-header::before {
        content: ''; position: absolute; top: -30px; right: -30px;
        width: 200px; height: 200px; border-radius: 50%;
        background: rgba(184,150,78,0.08); pointer-events: none;
    }
    .page-header::after {
        content: ''; position: absolute; bottom: -40px; right: 120px;
        width: 120px; height: 120px; border-radius: 50%;
        background: rgba(184,150,78,0.05); pointer-events: none;
    }
    .page-header-content { position: relative; z-index: 1; }
    .page-header h1 { font-size: 2rem; font-weight: 700; color: var(--cream); margin: 0 0 8px; display: flex; align-items: center; gap: 12px; }
    .page-header h1 i { color: var(--gold-light); }
    .page-header .lead { font-size: 14px; color: rgba(247,243,237,0.7); margin: 0; }
    .page-header-meta { position: relative; z-index: 1; text-align: right; }
    .page-header-meta .date-label { font-size: 11px; color: rgba(212,174,106,0.6); text-transform: uppercase; letter-spacing: 0.1em; }
    .page-header-meta .date-value { font-size: 14px; color: var(--gold-light); font-weight: 600; }

    /* Stat Cards */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
    .stat-card {
        background: var(--ivory); border: 1px solid var(--border);
        border-radius: var(--radius); padding: 24px;
        box-shadow: var(--shadow-sm); transition: all 0.25s ease;
        position: relative; overflow: hidden;
    }
    .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .stat-card::after {
        content: ''; position: absolute; top: 0; right: 0;
        width: 80px; height: 80px; border-radius: 0 var(--radius) 0 80px;
        opacity: 0.06;
    }
    .stat-card.businesses::after { background: #1e2d40; }
    .stat-card.stalls::after { background: #b8964e; }
    .stat-card.languages::after { background: #3a7d4f; }
    .stat-card.narrations::after { background: #6b4c9a; }
    .stat-icon {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 16px; flex-shrink: 0;
    }
    .stat-icon i { font-size: 22px; }
    .stat-icon.businesses { background: rgba(30,45,64,0.1); }
    .stat-icon.businesses i { color: var(--navy); }
    .stat-icon.stalls { background: rgba(184,150,78,0.12); }
    .stat-icon.stalls i { color: var(--gold); }
    .stat-icon.languages { background: rgba(58,125,79,0.12); }
    .stat-icon.languages i { color: #3a7d4f; }
    .stat-icon.narrations { background: rgba(107,76,154,0.12); }
    .stat-icon.narrations i { color: #6b4c9a; }
    .stat-number { font-size: 2.2rem; font-weight: 700; color: var(--text-dark); line-height: 1; margin-bottom: 6px; }
    .stat-label { font-size: 12.5px; font-weight: 600; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.06em; }
    .stat-link { font-size: 12px; color: var(--gold); text-decoration: none; display: inline-flex; align-items: center; gap: 4px; margin-top: 12px; transition: gap 0.2s; }
    .stat-link:hover { color: var(--gold-light); gap: 7px; }

    /* Section Header */
    .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .section-title { font-size: 16px; font-weight: 700; color: var(--text-dark); display: flex; align-items: center; gap: 8px; }
    .section-title i { color: var(--gold); }
    .btn-view-all {
        font-size: 12px; font-weight: 600; color: var(--gold); text-decoration: none;
        border: 1.5px solid var(--gold-pale); border-radius: var(--radius-sm);
        padding: 5px 14px; transition: all 0.2s ease; display: inline-flex; align-items: center; gap: 5px;
    }
    .btn-view-all:hover { background: var(--gold-pale); color: var(--navy); border-color: var(--gold); }

    /* Cards */
    .card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); }
    .card-body { padding: 0; }

    /* Tables */
    .table { margin: 0; font-size: 13.5px; }
    .table thead { background: var(--cream-dark); }
    .table thead th { font-size: 11.5px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); border-bottom: 2px solid var(--border); padding: 12px 16px; white-space: nowrap; }
    .table tbody td { padding: 14px 16px; vertical-align: middle; border-bottom: 1px solid var(--border); color: var(--text-dark); }
    .table tbody tr { background: #fff; transition: background 0.15s; }
    .table tbody tr:hover { background: var(--cream); }
    .table tbody tr:last-child td { border-bottom: none; }

    /* Badges */
    .badge-active { background: rgba(58,125,79,0.12); color: #3a7d4f; border: 1px solid rgba(58,125,79,0.25); padding: 3px 10px; border-radius: 20px; font-size: 11.5px; font-weight: 600; white-space: nowrap; }
    .badge-inactive { background: rgba(162,73,58,0.1); color: #a2493a; border: 1px solid rgba(162,73,58,0.2); padding: 3px 10px; border-radius: 20px; font-size: 11.5px; font-weight: 600; white-space: nowrap; }
    .plan-badge { font-size: 11.5px; font-weight: 600; padding: 3px 10px; border-radius: 20px; border: 1px solid; white-space: nowrap; }
    .plan-free { background: rgba(113,128,150,0.1); color: var(--text-mid); border-color: rgba(113,128,150,0.25); }
    .plan-basic { background: rgba(30,45,64,0.1); color: var(--navy); border-color: rgba(30,45,64,0.2); }
    .plan-pro { background: rgba(184,150,78,0.12); color: #8b6e2f; border-color: rgba(184,150,78,0.3); }
    .plan-enterprise { background: rgba(107,76,154,0.1); color: #6b4c9a; border-color: rgba(107,76,154,0.25); }

    /* Icon wrap */
    .item-icon { width: 34px; height: 34px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: rgba(30,45,64,0.07); }
    .item-icon i { font-size: 15px; color: var(--navy-light); }
    .item-name { font-weight: 600; color: var(--text-dark); font-size: 13.5px; }
    .item-sub { font-size: 12px; color: var(--text-light); }

    /* Language list */
    .lang-list { display: flex; flex-wrap: wrap; gap: 10px; padding: 20px; }
    .lang-chip {
        display: inline-flex; align-items: center; gap: 8px;
        background: #fff; border: 1px solid var(--border); border-radius: 8px;
        padding: 8px 14px; font-size: 13px; color: var(--text-dark);
        transition: all 0.2s ease;
    }
    .lang-chip:hover { border-color: var(--gold); background: var(--gold-pale); }
    .lang-flag { font-size: 18px; line-height: 1; }
    .lang-name { font-weight: 600; }
    .lang-code { font-size: 11px; color: var(--text-light); background: var(--cream-dark); padding: 1px 6px; border-radius: 4px; font-family: monospace; }

    /* Empty state */
    .empty-state { text-align: center; padding: 40px 20px; color: var(--text-light); }
    .empty-state i { font-size: 36px; margin-bottom: 10px; display: block; opacity: 0.5; }
    .empty-state p { font-size: 13px; margin: 0; }

    /* Quick actions */
    .quick-actions { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 16px; }
    .quick-action-btn {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 14px; border-radius: var(--radius-sm);
        background: #fff; border: 1px solid var(--border);
        text-decoration: none; color: var(--text-dark);
        font-size: 13px; font-weight: 500; transition: all 0.2s ease;
    }
    .quick-action-btn:hover { border-color: var(--gold); background: var(--gold-pale); color: var(--navy); box-shadow: var(--shadow-sm); }
    .quick-action-btn i { font-size: 18px; color: var(--gold); flex-shrink: 0; }

    /* Section card wrapper */
    .section-card { margin-bottom: 24px; }
    .section-card-header { background: var(--cream-dark); border: 1px solid var(--border); border-bottom: none; border-radius: var(--radius) var(--radius) 0 0; padding: 14px 20px; display: flex; justify-content: space-between; align-items: center; }
    .section-card-body { background: var(--ivory); border: 1px solid var(--border); border-radius: 0 0 var(--radius) var(--radius); overflow: hidden; }

    /* Animations */
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.4s ease 0.05s both; }
    .anim-2 { animation: fadeUp 0.4s ease 0.10s both; }
    .anim-3 { animation: fadeUp 0.4s ease 0.15s both; }
    .anim-4 { animation: fadeUp 0.4s ease 0.20s both; }
    .anim-5 { animation: fadeUp 0.4s ease 0.25s both; }

    /* Orders widget */
    .orders-summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--border); }
    .order-metric { text-align: center; }
    .order-metric-value { font-size: 1.5rem; font-weight: 700; color: var(--text-dark); }
    .order-metric-value.revenue { color: #3a7d4f; }
    .order-metric-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-light); margin-top: 2px; }
    .order-status-badge { font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 12px; white-space: nowrap; }
    .order-status-completed { background: rgba(58,125,79,0.12); color: #3a7d4f; border: 1px solid rgba(58,125,79,0.25); }
    .order-status-failed { background: rgba(162,73,58,0.1); color: #a2493a; border: 1px solid rgba(162,73,58,0.2); }
    .order-status-pending { background: rgba(184,150,78,0.12); color: #8b6e2f; border: 1px solid rgba(184,150,78,0.3); }
    .amount-vnd { font-weight: 600; color: var(--navy); font-size: 13px; }

    /* Spinner */
    .widget-loading { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 36px; color: var(--text-light); font-size: 13px; }
    .spinner { width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.7s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Refresh btn */
    .btn-refresh { font-size: 12px; color: var(--text-light); background: none; border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 4px 10px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; transition: all 0.2s; }
    .btn-refresh:hover { border-color: var(--gold); color: var(--gold); }
    .btn-refresh.loading i { animation: spin 0.7s linear infinite; }
    .api-error { padding: 20px; text-align: center; color: #a2493a; font-size: 13px; }
    .api-error i { font-size: 24px; display: block; margin-bottom: 6px; }

    @@media (max-width: 1100px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 576px) {
        .stats-grid { grid-template-columns: 1fr; }
        .page-header { padding: 24px 20px; }
        .page-header h1 { font-size: 1.5rem; }
        .orders-summary { grid-template-columns: 1fr; gap: 8px; }
    }
</style>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item">Admin</li>
        <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header anim-1">
    <div class="page-header-content">
        <h1><i class="bi bi-speedometer2"></i>Admin Dashboard</h1>
        <p class="lead">Tổng quan hệ thống quản lý chợ ẩm thực</p>
    </div>
    <div class="page-header-meta">
        <div class="date-label">Ngày cập nhật</div>
        <div class="date-value">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
</div>

<!-- Stat Cards -->
<div class="stats-grid anim-2">
    <div class="stat-card businesses">
        <div class="stat-icon businesses"><i class="bi bi-building"></i></div>
        <div class="stat-number">@Model.TotalBusinesses</div>
        <div class="stat-label">Tổng Businesses</div>
        <a asp-controller="Business" asp-action="Index" class="stat-link">
            Xem tất cả <i class="bi bi-arrow-right"></i>
        </a>
    </div>
    <div class="stat-card stalls">
        <div class="stat-icon stalls"><i class="bi bi-shop-window"></i></div>
        <div class="stat-number">@Model.TotalStalls</div>
        <div class="stat-label">Tổng Stalls (Quầy)</div>
        <a asp-controller="Stall" asp-action="Index" class="stat-link">
            Xem tất cả <i class="bi bi-arrow-right"></i>
        </a>
    </div>
    <div class="stat-card languages">
        <div class="stat-icon languages"><i class="bi bi-translate"></i></div>
        <div class="stat-number">@Model.ActiveLanguages</div>
        <div class="stat-label">Ngôn ngữ hoạt động</div>
        <span class="stat-link" style="color: var(--text-light); cursor: default;">
            <i class="bi bi-check-circle"></i> Đang kích hoạt
        </span>
    </div>
    <div class="stat-card narrations">
        <div class="stat-icon narrations"><i class="bi bi-volume-up"></i></div>
        <div class="stat-number">@Model.TotalNarrationContents</div>
        <div class="stat-label">Nội dung thuyết minh</div>
        <a asp-controller="Narration" asp-action="StallNarrationContents" class="stat-link">
            Xem tất cả <i class="bi bi-arrow-right"></i>
        </a>
    </div>
</div>

<!-- Main Content Grid -->
<div class="row g-4">

    <!-- Left: Recent Businesses + Recent Stalls -->
    <div class="col-lg-8">

        <!-- Recent Businesses -->
        <div class="section-card anim-3">
            <div class="section-card-header">
                <div class="section-title">
                    <i class="bi bi-building"></i>Businesses mới nhất
                </div>
                <a asp-controller="Business" asp-action="Index" class="btn-view-all">
                    Xem tất cả <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="section-card-body">
                @if (Model.RecentBusinesses.Count == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-building-slash"></i>
                        <p>Chưa có business nào được đăng ký.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0" aria-label="Recent businesses">
                            <thead>
                                <tr>
                                    <th>Tên Business</th>
                                    <th>Gói</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày tạo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.RecentBusinesses)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="item-icon"><i class="bi bi-building"></i></div>
                                                <div>
                                                    <div class="item-name">@b.Name</div>
                                                    @if (!string.IsNullOrWhiteSpace(b.ContactEmail))
                                                    {
                                                        <div class="item-sub">@b.ContactEmail</div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @{
                                                var planClass = b.Plan?.ToLower() switch {
                                                    "pro" => "plan-pro",
                                                    "basic" => "plan-basic",
                                                    "enterprise" => "plan-enterprise",
                                                    _ => "plan-free"
                                                };
                                            }
                                            <span class="plan-badge @planClass">@(b.Plan ?? "Free")</span>
                                        </td>
                                        <td>
                                            @if (b.IsActive)
                                            {
                                                <span class="badge-active">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge-inactive">Inactive</span>
                                            }
                                        </td>
                                        <td style="color: var(--text-light); font-size: 12.5px;">
                                            @b.CreatedAt.ToString("dd/MM/yyyy")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Recent Stalls -->
        <div class="section-card anim-4">
            <div class="section-card-header">
                <div class="section-title">
                    <i class="bi bi-shop-window"></i>Stalls mới nhất
                </div>
                <a asp-controller="Stall" asp-action="Index" class="btn-view-all">
                    Xem tất cả <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="section-card-body">
                @if (Model.RecentStalls.Count == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-shop"></i>
                        <p>Chưa có quầy nào được tạo.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0" aria-label="Recent stalls">
                            <thead>
                                <tr>
                                    <th>Tên Quầy</th>
                                    <th>Slug</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày tạo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.RecentStalls)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="item-icon"><i class="bi bi-shop-window"></i></div>
                                                <div>
                                                    <div class="item-name">@s.Name</div>
                                                    @if (!string.IsNullOrWhiteSpace(s.Description))
                                                    {
                                                        <div class="item-sub" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@s.Description</div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <code style="font-size:12px;background:var(--cream-dark);padding:2px 6px;border-radius:4px;color:var(--navy-light);">@s.Slug</code>
                                        </td>
                                        <td>
                                            @if (s.IsActive)
                                            {
                                                <span class="badge-active">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge-inactive">Inactive</span>
                                            }
                                        </td>
                                        <td style="color: var(--text-light); font-size: 12.5px;">
                                            @s.CreatedAt.ToString("dd/MM/yyyy")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- Right: Quick Actions + Languages -->
    <div class="col-lg-4">

        <!-- Quick Actions -->
        <div class="section-card anim-3">
            <div class="section-card-header">
                <div class="section-title">
                    <i class="bi bi-lightning-charge"></i>Thao tác nhanh
                </div>
            </div>
            <div class="section-card-body">
                <div class="quick-actions">
                    <a asp-controller="Business" asp-action="Index" class="quick-action-btn">
                        <i class="bi bi-building-add"></i>
                        <span>Thêm Business</span>
                    </a>
                    <a asp-controller="Stall" asp-action="Index" class="quick-action-btn">
                        <i class="bi bi-shop-window"></i>
                        <span>Thêm Stall</span>
                    </a>
                    <a asp-controller="Admin" asp-action="UserRoleManagement" class="quick-action-btn">
                        <i class="bi bi-people"></i>
                        <span>Quản lý User</span>
                    </a>
                    <a asp-controller="Admin" asp-action="QrCodes" class="quick-action-btn">
                        <i class="bi bi-qr-code"></i>
                        <span>Mã QR</span>
                    </a>
                    <a asp-controller="Admin" asp-action="Subscription" class="quick-action-btn">
                        <i class="bi bi-credit-card"></i>
                        <span>Subscription</span>
                    </a>
                    <a asp-controller="Admin" asp-action="SubscriptionOrders" class="quick-action-btn">
                        <i class="bi bi-receipt"></i>
                        <span>Đơn hàng</span>
                    </a>
                    <a asp-controller="Narration" asp-action="StallNarrationContents" class="quick-action-btn">
                        <i class="bi bi-volume-up"></i>
                        <span>Thuyết minh</span>
                    </a>
                    <a asp-controller="StallLocation" asp-action="Index" class="quick-action-btn">
                        <i class="bi bi-map"></i>
                        <span>Bản đồ</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Recent Orders (client-side API fetch) -->
        <div class="section-card anim-4">
            <div class="section-card-header">
                <div class="section-title">
                    <i class="bi bi-receipt"></i>Đơn hàng gần đây
                </div>
                <button class="btn-refresh" id="btnRefreshOrders" onclick="loadRecentOrders()">
                    <i class="bi bi-arrow-clockwise" id="refreshIcon"></i> Refresh
                </button>
            </div>
            <div class="section-card-body">
                <!-- Summary metrics -->
                <div id="ordersSummary" style="display:none;">
                    <div class="orders-summary">
                        <div class="order-metric">
                            <div class="order-metric-value" id="metricTotal">0</div>
                            <div class="order-metric-label">Tổng đơn</div>
                        </div>
                        <div class="order-metric">
                            <div class="order-metric-value" id="metricCompleted">0</div>
                            <div class="order-metric-label">Thành công</div>
                        </div>
                        <div class="order-metric">
                            <div class="order-metric-value revenue" id="metricRevenue">0</div>
                            <div class="order-metric-label">Doanh thu (VND)</div>
                        </div>
                    </div>
                </div>
                <!-- Table -->
                <div id="ordersContainer">
                    <div class="widget-loading">
                        <div class="spinner"></div>
                        <span>Đang tải từ API...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Languages -->
        <div class="section-card anim-5">
            <div class="section-card-header">
                <div class="section-title">
                    <i class="bi bi-translate"></i>Ngôn ngữ hoạt động
                    <span style="font-size:12px;font-weight:400;color:var(--text-light);margin-left:4px;">(@Model.Languages.Count)</span>
                </div>
            </div>
            <div class="section-card-body">
                @if (Model.Languages.Count == 0)
                {
                    <div class="empty-state">
                        <i class="bi bi-globe"></i>
                        <p>Chưa có ngôn ngữ nào được kích hoạt.</p>
                    </div>
                }
                else
                {
                    <div class="lang-list">
                        @foreach (var lang in Model.Languages)
                        {
                            <div class="lang-chip">
                                @if (!string.IsNullOrWhiteSpace(lang.FlagCode))
                                {
                                    <span class="lang-flag">@lang.FlagCode</span>
                                }
                                else
                                {
                                    <i class="bi bi-globe" style="font-size:16px;color:var(--text-light);"></i>
                                }
                                <span class="lang-name">@(lang.DisplayName ?? lang.Name)</span>
                                <span class="lang-code">@lang.Code</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    const API_BASE = '@apiBase';

    function fmtVnd(amount) {
        return new Intl.NumberFormat('vi-VN').format(amount) + ' ₫';
    }

    function fmtDate(iso) {
        if (!iso) return '-';
        const d = new Date(iso);
        return d.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
    }

    function statusBadge(status) {
        if (!status) return '';
        const map = {
            'Completed': ['order-status-completed', 'Thành công'],
            'Failed':    ['order-status-failed',    'Thất bại'],
            'Pending':   ['order-status-pending',   'Đang xử lý']
        };
        const [cls, label] = map[status] ?? ['order-status-pending', status];
        return `<span class="order-status-badge ${cls}">${label}</span>`;
    }

    function planBadge(plan) {
        const map = { 'Pro': 'plan-pro', 'Basic': 'plan-basic', 'Enterprise': 'plan-enterprise' };
        return `<span class="plan-badge ${map[plan] ?? 'plan-free'}">${plan ?? 'Free'}</span>`;
    }

    async function loadRecentOrders() {
        const token = localStorage.getItem('jwtToken');
        const container = document.getElementById('ordersContainer');
        const summary = document.getElementById('ordersSummary');
        const btn = document.getElementById('btnRefreshOrders');
        const icon = document.getElementById('refreshIcon');

        // Loading state
        btn.classList.add('loading');
        summary.style.display = 'none';
        container.innerHTML = `
            <div class="widget-loading">
                <div class="spinner"></div>
                <span>Đang tải từ API...</span>
            </div>`;

        try {
            const res = await fetch(`${API_BASE}/api/subscription-orders?page=1&pageSize=8`, {
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!res.ok) {
                const errText = res.status === 401 ? 'Không có quyền truy cập (401).'
                              : res.status === 403 ? 'Yêu cầu quyền Admin (403).'
                              : `Lỗi API: ${res.status}`;
                container.innerHTML = `<div class="api-error"><i class="bi bi-exclamation-triangle"></i>${errText}</div>`;
                return;
            }

            const json = await res.json();
            const items = json?.data?.items ?? [];
            const totalCount = json?.data?.totalCount ?? 0;

            // Tính metrics
            const completed = items.filter(o => o.status === 'Completed');
            const revenue = completed.reduce((s, o) => s + (o.amount ?? 0), 0);

            document.getElementById('metricTotal').textContent = totalCount;
            document.getElementById('metricCompleted').textContent = completed.length;
            document.getElementById('metricRevenue').textContent = fmtVnd(revenue);
            summary.style.display = '';

            if (items.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-receipt"></i>
                        <p>Chưa có đơn hàng nào.</p>
                    </div>`;
                return;
            }

            const rows = items.map(o => `
                <tr>
                    <td>
                        <div class="item-name" style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                             title="${o.businessName ?? ''}">${o.businessName ?? '-'}</div>
                    </td>
                    <td>${planBadge(o.plan)}</td>
                    <td><span class="amount-vnd">${fmtVnd(o.amount)}</span></td>
                    <td>${statusBadge(o.status)}</td>
                    <td style="color:var(--text-light);font-size:12px;">${fmtDate(o.createdAt)}</td>
                </tr>`).join('');

            container.innerHTML = `
                <div class="table-responsive">
                    <table class="table mb-0" aria-label="Recent orders">
                        <thead>
                            <tr>
                                <th>Business</th>
                                <th>Gói</th>
                                <th>Số tiền</th>
                                <th>Trạng thái</th>
                                <th>Ngày</th>
                            </tr>
                        </thead>
                        <tbody>${rows}</tbody>
                    </table>
                </div>`;

        } catch (err) {
            container.innerHTML = `<div class="api-error"><i class="bi bi-wifi-off"></i>Không thể kết nối API.<br><small>${err.message}</small></div>`;
        } finally {
            btn.classList.remove('loading');
        }
    }

    // Tự động load khi trang mở
    document.addEventListener('DOMContentLoaded', loadRecentOrders);
</script>
}
