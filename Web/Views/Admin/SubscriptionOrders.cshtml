@model Web.Models.SubscriptionOrdersViewModel
@{
    ViewData["Title"] = "Subscription Orders";
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex   = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed; --cream-dark: #ede8df; --ivory: #faf8f4;
        --navy: #1e2d40; --navy-mid: #2c3e55; --navy-light: #3d5068;
        --gold: #b8964e; --gold-light: #d4ae6a; --gold-pale: #f0e4c8;
        --text-dark: #1e2d40; --text-mid: #4a5568; --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --shadow-lg: 0 8px 32px rgba(30,45,64,0.13);
        --radius: 10px; --radius-sm: 6px;
    }

    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

    /* Header */
    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius); padding: 32px 40px; margin-bottom: 28px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 20px; box-shadow: var(--shadow-md);
        position: relative; overflow: hidden;
    }
    .page-header::before { content: ''; position: absolute; top: -20px; right: -20px; width: 160px; height: 160px; border-radius: 50%; background: rgba(184,150,78,0.08); pointer-events: none; }
    .page-header-content { position: relative; z-index: 1; }
    .page-header h1 { font-size: 2rem; font-weight: 700; color: var(--cream); margin: 0 0 8px; display: flex; align-items: center; gap: 12px; }
    .page-header h1 i { color: var(--gold-light); }
    .page-header .lead { font-size: 14px; color: rgba(247,243,237,0.7); margin: 0; }

    /* Stat cards */
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .stat-card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px 22px; box-shadow: var(--shadow-sm); display: flex; align-items: center; gap: 14px; }
    .stat-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .stat-icon i { font-size: 20px; }
    .stat-icon.total    { background: rgba(30,45,64,0.08);    } .stat-icon.total i    { color: var(--navy); }
    .stat-icon.success  { background: rgba(58,125,79,0.10);   } .stat-icon.success i  { color: #3a7d4f; }
    .stat-icon.failed   { background: rgba(162,73,58,0.09);   } .stat-icon.failed i   { color: #a2493a; }
    .stat-icon.revenue  { background: rgba(184,150,78,0.12);  } .stat-icon.revenue i  { color: var(--gold); }
    .stat-number { font-size: 1.6rem; font-weight: 700; color: var(--text-dark); line-height: 1; }
    .stat-number.revenue { color: #3a7d4f; font-size: 1.3rem; }
    .stat-label  { font-size: 11.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-light); margin-top: 3px; }

    /* Filter card */
    .filter-card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); padding: 20px 24px; margin-bottom: 24px; }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px; }
    .form-control, .form-select { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 8px 13px; font-size: 13.5px; color: var(--text-dark); background: #fff; transition: all 0.2s; }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.1); outline: none; }
    .btn-classic { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 600; padding: 7px 14px; border-radius: var(--radius-sm); border: 1.5px solid; text-decoration: none; transition: all 0.18s; background: transparent; white-space: nowrap; cursor: pointer; }
    .btn-classic.navy { border-color: var(--navy); color: var(--navy); }
    .btn-classic.navy:hover { background: var(--navy); color: var(--cream); }

    /* Table card */
    .table-card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); }
    .table-card-header { background: var(--cream-dark); border-bottom: 1px solid var(--border); padding: 14px 24px; display: flex; justify-content: space-between; align-items: center; border-radius: var(--radius) var(--radius) 0 0; font-size: 13.5px; }
    .table-card-footer { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 14px 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; border-radius: 0 0 var(--radius) var(--radius); }
    .table { margin: 0; font-size: 13.5px; }
    .table thead { background: var(--cream-dark); }
    .table thead th { font-size: 11.5px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); border-bottom: 2px solid var(--border); padding: 12px 16px; white-space: nowrap; }
    .table tbody td { padding: 14px 16px; vertical-align: middle; border-bottom: 1px solid var(--border); }
    .table tbody tr { background: #fff; transition: background 0.15s; }
    .table tbody tr:hover { background: var(--cream); }
    .table tbody tr:last-child td { border-bottom: none; }

    /* Badges */
    .status-badge { font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; border: 1px solid; white-space: nowrap; display: inline-flex; align-items: center; gap: 5px; }
    .status-completed { background: rgba(58,125,79,0.10);  color: #3a7d4f; border-color: rgba(58,125,79,0.28); }
    .status-failed    { background: rgba(162,73,58,0.10);  color: #a2493a; border-color: rgba(162,73,58,0.25); }
    .status-pending   { background: rgba(184,150,78,0.10); color: #8b6e2f; border-color: rgba(184,150,78,0.28); }
    .plan-badge { font-size: 12px; font-weight: 700; padding: 3px 10px; border-radius: 20px; border: 1.5px solid; white-space: nowrap; }
    .plan-free  { background: rgba(113,128,150,0.09); color: #5c6b7c; border-color: rgba(113,128,150,0.22); }
    .plan-basic { background: rgba(30,45,64,0.09);   color: var(--navy); border-color: rgba(30,45,64,0.2); }
    .plan-pro   { background: rgba(184,150,78,0.12); color: #7a5c1e;  border-color: rgba(184,150,78,0.3); }

    /* Amount */
    .amount-vnd { font-weight: 700; color: var(--text-dark); font-size: 13.5px; }
    .amount-vnd.success { color: #3a7d4f; }
    .amount-vnd.failed  { color: var(--text-light); text-decoration: line-through; }

    /* Card row */
    .card-last4 { font-family: monospace; font-size: 13px; background: var(--cream-dark); padding: 2px 7px; border-radius: 4px; color: var(--navy-light); letter-spacing: 0.08em; }

    /* Biz name cell */
    .biz-name { font-weight: 600; font-size: 13.5px; color: var(--text-dark); }

    /* Date cells */
    .date-main { font-size: 13px; color: var(--text-dark); }
    .date-sub  { font-size: 11.5px; color: var(--text-light); }

    /* Pagination */
    .pagination { gap: 4px; }
    .pagination .page-link { border: 1px solid var(--border); color: var(--text-dark); padding: 6px 12px; font-size: 13px; border-radius: var(--radius-sm); transition: all 0.18s; }
    .pagination .page-link:hover { background: var(--gold-pale); border-color: var(--gold); color: var(--navy); }
    .pagination .page-item.active .page-link { background: var(--gold); border-color: var(--gold); color: var(--navy); font-weight: 600; }
    .pagination .page-item.disabled .page-link { background: var(--cream); border-color: var(--border); color: var(--text-light); pointer-events: none; }

    /* Empty state */
    .empty-state { text-align: center; padding: 60px 20px; color: var(--text-light); }
    .empty-state i { font-size: 48px; margin-bottom: 12px; display: block; opacity: 0.45; }
    .empty-state p { font-size: 13.5px; margin: 0; }

    /* Detail modal */
    .modal-content { border: none; border-radius: var(--radius); box-shadow: var(--shadow-lg); }
    .modal-header { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%); border-bottom: none; border-radius: var(--radius) var(--radius) 0 0; padding: 20px 24px; }
    .modal-header .modal-title { font-size: 17px; font-weight: 700; color: var(--cream); display: flex; align-items: center; gap: 10px; }
    .modal-header .modal-title i { color: var(--gold-light); }
    .modal-header .btn-close { filter: brightness(0) invert(1); opacity: 0.7; }
    .modal-header .btn-close:hover { opacity: 1; }
    .modal-body { padding: 24px; background: var(--ivory); }
    .modal-footer { background: var(--cream-dark); border-top: 1px solid var(--border); border-radius: 0 0 var(--radius) var(--radius); padding: 14px 24px; }
    .detail-row { display: flex; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid var(--border); gap: 16px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { font-size: 11.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-light); width: 140px; flex-shrink: 0; padding-top: 1px; }
    .detail-value { font-size: 13.5px; color: var(--text-dark); flex: 1; }

    @@keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.4s ease 0.05s both; }
    .anim-2 { animation: fadeUp 0.4s ease 0.10s both; }
    .anim-3 { animation: fadeUp 0.4s ease 0.15s both; }
    .anim-4 { animation: fadeUp 0.4s ease 0.20s both; }

    @@media (max-width: 992px) { .stats-row { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 576px) {
        .stats-row { grid-template-columns: 1fr 1fr; }
        .page-header { padding: 24px 20px; }
        .page-header h1 { font-size: 1.5rem; }
    }
</style>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Dashboard">Admin</a></li>
        <li class="breadcrumb-item active" aria-current="page">Subscription Orders</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header anim-1">
    <div class="page-header-content">
        <h1><i class="bi bi-receipt"></i>Subscription Orders</h1>
        <p class="lead">Lịch sử đơn hàng đăng ký gói của các business trong hệ thống.</p>
    </div>
</div>

<!-- Alerts -->
@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show anim-1" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show anim-1" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stat Cards -->
<div class="stats-row anim-2">
    <div class="stat-card">
        <div class="stat-icon total"><i class="bi bi-receipt"></i></div>
        <div>
            <div class="stat-number">@Model.TotalCount</div>
            <div class="stat-label">Tổng đơn</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon success"><i class="bi bi-check-circle"></i></div>
        <div>
            <div class="stat-number">@Model.TotalCompleted</div>
            <div class="stat-label">Thành công</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon failed"><i class="bi bi-x-circle"></i></div>
        <div>
            <div class="stat-number">@Model.TotalFailed</div>
            <div class="stat-label">Thất bại</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon revenue"><i class="bi bi-cash-coin"></i></div>
        <div>
            <div class="stat-number revenue">@Model.TotalRevenue.ToString("N0") ₫</div>
            <div class="stat-label">Doanh thu (trang này)</div>
        </div>
    </div>
</div>

<!-- Filter -->
<div class="filter-card anim-3">
    <form method="get" asp-action="SubscriptionOrders" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Lọc theo gói</label>
            <select name="plan" class="form-select">
                <option value="">— Tất cả —</option>
                <option value="Free"  selected="@(Model.FilterPlan == "Free"  ? "selected" : null)">Free</option>
                <option value="Basic" selected="@(Model.FilterPlan == "Basic" ? "selected" : null)">Basic</option>
                <option value="Pro"   selected="@(Model.FilterPlan == "Pro"   ? "selected" : null)">Pro</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Lọc theo trạng thái</label>
            <select name="status" class="form-select">
                <option value="">— Tất cả —</option>
                <option value="Completed" selected="@(Model.FilterStatus == "Completed" ? "selected" : null)">Thành công</option>
                <option value="Failed"    selected="@(Model.FilterStatus == "Failed"    ? "selected" : null)">Thất bại</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Số dòng / trang</label>
            <select name="pageSize" class="form-select">
                @foreach (var s in new[] { 10, 20, 30, 50 })
                {
                    <option value="@s" selected="@(Model.PageSize == s ? "selected" : null)">@s</option>
                }
            </select>
        </div>
        <div class="col-auto d-flex gap-2 align-items-end">
            <button type="submit" class="btn-classic navy"><i class="bi bi-funnel"></i>Lọc</button>
            <a asp-action="SubscriptionOrders" class="btn-classic navy"><i class="bi bi-x-circle"></i>Xoá lọc</a>
        </div>
    </form>
</div>

<!-- Table -->
<div class="table-card anim-4">
    <div class="table-card-header">
        <span>
            <strong>@Model.TotalCount</strong> đơn hàng
            @if (!string.IsNullOrWhiteSpace(Model.FilterPlan) || !string.IsNullOrWhiteSpace(Model.FilterStatus))
            {
                <span class="text-muted" style="font-size:12.5px;">
                    — đang lọc:
                    @if (!string.IsNullOrWhiteSpace(Model.FilterPlan)) { <span>Gói <strong>@Model.FilterPlan</strong></span> }
                    @if (!string.IsNullOrWhiteSpace(Model.FilterStatus)) { <span> · <strong>@Model.FilterStatus</strong></span> }
                </span>
            }
        </span>
        <a asp-controller="Admin" asp-action="Subscription" class="btn-classic navy" style="font-size:12px;">
            <i class="bi bi-credit-card"></i>Quản lý gói
        </a>
    </div>

    <div class="table-responsive">
        <table class="table" aria-label="Subscription orders">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Business</th>
                    <th>Gói</th>
                    <th>Số tiền</th>
                    <th>Thẻ</th>
                    <th>Trạng thái</th>
                    <th>Hiệu lực</th>
                    <th>Ngày tạo</th>
                    <th class="text-end">Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="9">
                            <div class="empty-state">
                                <i class="bi bi-receipt"></i>
                                <p>Không có đơn hàng nào.</p>
                                @if (!string.IsNullOrWhiteSpace(Model.FilterPlan) || !string.IsNullOrWhiteSpace(Model.FilterStatus))
                                {
                                    <p class="mt-1 text-muted" style="font-size:12px;">Thử xoá bộ lọc.</p>
                                }
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    var rowNum = startIndex;
                    foreach (var o in Model.Items)
                    {
                        var isCompleted = o.Status == "Completed";
                        var isFailed    = o.Status == "Failed";
                        var planCls = o.Plan?.ToLower() switch {
                            "pro"   => "plan-pro",
                            "basic" => "plan-basic",
                            _       => "plan-free"
                        };

                        <tr>
                            <td style="color:var(--text-light);font-size:12.5px;">@rowNum</td>
                            <td>
                                <div class="biz-name">@o.BusinessName</div>
                            </td>
                            <td>
                                <span class="plan-badge @planCls">@o.Plan</span>
                            </td>
                            <td>
                                <span class="amount-vnd @(isCompleted ? "success" : isFailed ? "failed" : "")">
                                    @o.Amount.ToString("N0") ₫
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(o.CardLastFour))
                                {
                                    <span class="card-last4">**** @o.CardLastFour</span>
                                }
                                else
                                {
                                    <span style="color:var(--text-light);">—</span>
                                }
                            </td>
                            <td>
                                @if (isCompleted)
                                {
                                    <span class="status-badge status-completed">
                                        <i class="bi bi-check-circle-fill"></i>Thành công
                                    </span>
                                }
                                else if (isFailed)
                                {
                                    <span class="status-badge status-failed">
                                        <i class="bi bi-x-circle-fill"></i>Thất bại
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-pending">
                                        <i class="bi bi-clock-fill"></i>@o.Status
                                    </span>
                                }
                            </td>
                            <td>
                                @if (isCompleted)
                                {
                                    <div class="date-main">@o.PlanStartAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
                                    <div class="date-sub">→ @o.PlanEndAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
                                }
                                else
                                {
                                    <span style="color:var(--text-light);font-size:13px;">—</span>
                                }
                            </td>
                            <td>
                                <div class="date-main">@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
                                <div class="date-sub">@o.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                            </td>
                            <td class="text-end">
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary"
                                        style="font-size:12px;padding:4px 10px;"
                                        onclick="openDetail(this)"
                                        data-id="@o.Id"
                                        data-bizname="@o.BusinessName"
                                        data-plan="@o.Plan"
                                        data-amount="@o.Amount.ToString("N0")"
                                        data-currency="@o.Currency"
                                        data-status="@o.Status"
                                        data-card="@(string.IsNullOrWhiteSpace(o.CardLastFour) ? "" : "**** " + o.CardLastFour)"
                                        data-created="@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")"
                                        data-paid="@(o.PaidAt.HasValue ? o.PaidAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "")"
                                        data-planstart="@(isCompleted ? o.PlanStartAt.ToLocalTime().ToString("dd/MM/yyyy") : "")"
                                        data-planend="@(isCompleted ? o.PlanEndAt.ToLocalTime().ToString("dd/MM/yyyy") : "")">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </td>
                        </tr>
                        rowNum++;
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalCount > 0)
    {
        <div class="table-card-footer">
            <span style="font-size:13px;color:var(--text-light);">
                Hiển thị @startIndex–@endIndex / @Model.TotalCount đơn
            </span>
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Orders pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="SubscriptionOrders"
                               asp-route-page="@(Model.Page - 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-plan="@Model.FilterPlan"
                               asp-route-status="@Model.FilterStatus">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link"
                                   asp-action="SubscriptionOrders"
                                   asp-route-page="@p"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-plan="@Model.FilterPlan"
                                   asp-route-status="@Model.FilterStatus">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="SubscriptionOrders"
                               asp-route-page="@(Model.Page + 1)"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-plan="@Model.FilterPlan"
                               asp-route-status="@Model.FilterStatus">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    }
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalLabel">
                    <i class="bi bi-receipt"></i>Chi tiết đơn hàng
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="detail-row">
                    <div class="detail-label">Business</div>
                    <div class="detail-value" id="dBizName">—</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Gói</div>
                    <div class="detail-value" id="dPlan">—</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Số tiền</div>
                    <div class="detail-value" id="dAmount">—</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Trạng thái</div>
                    <div class="detail-value" id="dStatus">—</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Thẻ thanh toán</div>
                    <div class="detail-value" id="dCard">—</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Ngày tạo</div>
                    <div class="detail-value" id="dCreated">—</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Ngày thanh toán</div>
                    <div class="detail-value" id="dPaid">—</div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Hiệu lực</div>
                    <div class="detail-value" id="dPeriod">—</div>
                </div>
                <div class="detail-row" style="border-bottom:none;">
                    <div class="detail-label">Order ID</div>
                    <div class="detail-value" id="dId" style="font-family:monospace;font-size:12px;word-break:break-all;">—</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openDetail(btn) {
        const d = btn.dataset;

        document.getElementById('dBizName').textContent  = d.bizname || '—';
        document.getElementById('dAmount').textContent   = d.amount ? d.amount + ' ' + (d.currency || 'VND') : '—';
        document.getElementById('dCard').textContent     = d.card || '—';
        document.getElementById('dCreated').textContent  = d.created || '—';
        document.getElementById('dPaid').textContent     = d.paid || '—';
        document.getElementById('dId').textContent       = d.id || '—';

        // Plan badge
        const planMap = { Pro: 'plan-pro', Basic: 'plan-basic', Free: 'plan-free' };
        document.getElementById('dPlan').innerHTML =
            `<span class="plan-badge ${planMap[d.plan] ?? 'plan-free'}">${d.plan ?? '—'}</span>`;

        // Status badge
        const statusMap = {
            Completed: ['status-completed', '<i class="bi bi-check-circle-fill"></i> Thành công'],
            Failed:    ['status-failed',    '<i class="bi bi-x-circle-fill"></i> Thất bại'],
        };
        const [cls, label] = statusMap[d.status] ?? ['status-pending', d.status];
        document.getElementById('dStatus').innerHTML =
            `<span class="status-badge ${cls}">${label}</span>`;

        // Period
        document.getElementById('dPeriod').textContent =
            d.planstart && d.planend ? `${d.planstart} → ${d.planend}` : '—';

        new bootstrap.Modal(document.getElementById('detailModal')).show();
    }
</script>
}
