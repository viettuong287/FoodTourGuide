@model Web.Models.PlansViewModel
@{
    ViewData["Title"] = "Gói dịch vụ";
    var highlight = Model.HighlightPlan ?? "Basic";   // card được làm nổi
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed; --cream-dark: #ede8df; --ivory: #faf8f4;
        --navy: #1e2d40; --navy-mid: #2c3e55; --navy-light: #3d5068;
        --gold: #b8964e; --gold-light: #d4ae6a; --gold-pale: #f0e4c8;
        --text-dark: #1e2d40; --text-mid: #4a5568; --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --shadow-lg: 0 8px 32px rgba(30,45,64,0.13);
        --radius: 10px; --radius-sm: 6px;
    }

    /* ── HERO ── */
    .plans-hero {
        text-align: center;
        padding: 52px 20px 44px;
        background: linear-gradient(160deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius);
        margin-bottom: 40px;
        position: relative; overflow: hidden;
    }
    .plans-hero::before { content:''; position:absolute; top:-40px; left:-40px; width:200px; height:200px; border-radius:50%; background:rgba(184,150,78,0.07); pointer-events:none; }
    .plans-hero::after  { content:''; position:absolute; bottom:-50px; right:-30px; width:180px; height:180px; border-radius:50%; background:rgba(184,150,78,0.05); pointer-events:none; }
    .plans-hero-tag { display:inline-flex; align-items:center; gap:6px; background:rgba(184,150,78,0.15); border:1px solid rgba(184,150,78,0.35); color:var(--gold-light); font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:4px 14px; border-radius:20px; margin-bottom:16px; }
    .plans-hero h1 { font-size:2.2rem; font-weight:800; color:var(--cream); margin-bottom:12px; line-height:1.2; }
    .plans-hero h1 span { color:var(--gold-light); }
    .plans-hero p  { font-size:15px; color:rgba(247,243,237,0.65); max-width:500px; margin:0 auto; line-height:1.7; }

    /* ── PLAN GRID ── */
    .plan-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:48px; align-items:stretch; }

    .plan-card {
        background:var(--ivory); border:1.5px solid var(--border);
        border-radius: var(--radius); box-shadow:var(--shadow-sm);
        display:flex; flex-direction:column;
        transition: transform 0.25s, box-shadow 0.25s;
        overflow: hidden; position:relative;
    }
    .plan-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
    .plan-card.featured {
        border-color: var(--gold);
        box-shadow: 0 8px 32px rgba(184,150,78,0.2);
        transform: translateY(-6px);
    }
    .plan-card.featured:hover { transform:translateY(-10px); }

    /* Featured ribbon */
    .plan-ribbon {
        position:absolute; top:16px; right:-28px;
        background:linear-gradient(135deg,var(--gold),var(--gold-light));
        color:var(--navy); font-size:10px; font-weight:800;
        letter-spacing:0.1em; text-transform:uppercase;
        padding:4px 36px; transform:rotate(35deg);
        box-shadow: 0 2px 8px rgba(184,150,78,0.4);
    }

    .plan-header { padding:28px 28px 20px; }
    .plan-icon { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:16px; }
    .plan-icon i { font-size:22px; }
    .plan-icon.free     { background:rgba(113,128,150,0.10); } .plan-icon.free i     { color:var(--text-mid); }
    .plan-icon.basic    { background:rgba(30,45,64,0.09);    } .plan-icon.basic i    { color:var(--navy); }
    .plan-icon.pro      { background:rgba(184,150,78,0.13);  } .plan-icon.pro i      { color:var(--gold); }
    .plan-name { font-size:1.1rem; font-weight:800; color:var(--text-dark); margin-bottom:6px; }
    .plan-tagline { font-size:13px; color:var(--text-light); line-height:1.5; min-height:40px; }
    .plan-price-wrap { margin-top:20px; display:flex; align-items:baseline; gap:4px; }
    .plan-price { font-size:2.2rem; font-weight:800; color:var(--text-dark); line-height:1; }
    .plan-price.free-price { font-size:1.8rem; color:var(--text-mid); }
    .plan-price-unit { font-size:13px; color:var(--text-light); }

    .plan-divider { border:none; border-top:1px solid var(--border); margin:0 28px; }

    .plan-features { padding:20px 28px; flex:1; }
    .plan-feature-list { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px; }
    .plan-feature-list li { display:flex; align-items:flex-start; gap:9px; font-size:13.5px; color:var(--text-mid); }
    .plan-feature-list li i.check  { color:#3a7d4f; font-size:14px; flex-shrink:0; margin-top:1px; }
    .plan-feature-list li i.cross  { color:#a2493a; font-size:14px; flex-shrink:0; margin-top:1px; }
    .plan-feature-list li i.dash   { color:var(--text-light); font-size:14px; flex-shrink:0; margin-top:1px; }
    .feature-strong { font-weight:600; color:var(--text-dark); }

    .plan-footer { padding:20px 28px 28px; }
    .btn-plan {
        display:flex; align-items:center; justify-content:center; gap:8px;
        width:100%; padding:12px 20px; border-radius:var(--radius-sm);
        font-size:14px; font-weight:700; text-decoration:none;
        cursor:pointer; transition:all 0.2s; border:none;
    }
    .btn-plan.gold    { background:linear-gradient(135deg,var(--gold),var(--gold-light)); color:var(--navy); box-shadow:0 3px 12px rgba(184,150,78,0.35); }
    .btn-plan.gold:hover { box-shadow:0 5px 20px rgba(184,150,78,0.45); transform:translateY(-1px); color:var(--navy); }
    .btn-plan.navy    { background:var(--navy); color:var(--cream); }
    .btn-plan.navy:hover { background:var(--navy-mid); color:var(--cream); }
    .btn-plan.outline { background:transparent; color:var(--text-mid); border:1.5px solid var(--border); }
    .btn-plan.outline:hover { border-color:var(--navy); color:var(--navy); }
    .btn-plan.current { background:var(--cream-dark); color:var(--text-light); cursor:default; pointer-events:none; border:1.5px solid var(--border); }
    .btn-plan-note { font-size:11.5px; color:var(--text-light); text-align:center; margin-top:8px; }

    /* ── COMPARISON TABLE ── */
    .compare-section { margin-bottom:48px; }
    .compare-title { font-size:1.4rem; font-weight:800; color:var(--text-dark); margin-bottom:6px; text-align:center; }
    .compare-sub   { font-size:14px; color:var(--text-light); text-align:center; margin-bottom:28px; }
    .compare-card  { background:var(--ivory); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow-sm); overflow:hidden; }
    .compare-table { margin:0; font-size:13.5px; }
    .compare-table thead tr { background:var(--navy); }
    .compare-table thead th { color:var(--cream); font-size:12px; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; padding:14px 20px; border:none; text-align:center; }
    .compare-table thead th:first-child { text-align:left; }
    .compare-table thead th.featured-col { background:rgba(184,150,78,0.25); color:var(--gold-light); }
    .compare-table tbody tr { border-bottom:1px solid var(--border); background:#fff; }
    .compare-table tbody tr:hover { background:var(--cream); }
    .compare-table tbody tr:last-child { border-bottom:none; }
    .compare-table tbody tr.group-header td { background:var(--cream-dark); font-weight:700; font-size:12px; text-transform:uppercase; letter-spacing:0.06em; color:var(--text-light); padding:10px 20px; }
    .compare-table tbody td { padding:13px 20px; color:var(--text-mid); text-align:center; border:none; }
    .compare-table tbody td:first-child { text-align:left; color:var(--text-dark); font-weight:500; }
    .compare-table tbody td.featured-col { background:rgba(184,150,78,0.04); }
    .tick  { color:#3a7d4f; font-size:16px; }
    .cross { color:#a2493a; font-size:16px; }
    .val   { font-weight:600; color:var(--text-dark); }

    /* ── FAQ ── */
    .faq-section { margin-bottom:24px; }
    .faq-title { font-size:1.4rem; font-weight:800; color:var(--text-dark); margin-bottom:6px; text-align:center; }
    .faq-sub   { font-size:14px; color:var(--text-light); text-align:center; margin-bottom:28px; }
    .accordion-item  { background:var(--ivory); border:1px solid var(--border) !important; border-radius:var(--radius-sm) !important; margin-bottom:8px; overflow:hidden; }
    .accordion-button { background:var(--ivory) !important; color:var(--text-dark) !important; font-weight:600; font-size:14px; padding:16px 20px; box-shadow:none !important; }
    .accordion-button:not(.collapsed) { background:var(--cream-dark) !important; color:var(--navy) !important; border-bottom:1px solid var(--border); }
    .accordion-button::after { filter:opacity(0.5); }
    .accordion-body { font-size:13.5px; color:var(--text-mid); line-height:1.7; padding:16px 20px; background:#fff; }

    /* ── CTA BOTTOM ── */
    .cta-bottom {
        text-align:center; padding:40px 20px;
        background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 100%);
        border-radius:var(--radius); margin-bottom:8px;
        position:relative; overflow:hidden;
    }
    .cta-bottom::before { content:''; position:absolute; top:-30px; right:-30px; width:150px; height:150px; border-radius:50%; background:rgba(184,150,78,0.08); pointer-events:none; }
    .cta-bottom h2 { font-size:1.5rem; font-weight:800; color:var(--cream); margin-bottom:10px; }
    .cta-bottom p  { font-size:14px; color:rgba(247,243,237,0.65); margin-bottom:24px; }
    .btn-gold-lg { background:linear-gradient(135deg,var(--gold),var(--gold-light)); color:var(--navy); border:none; font-weight:700; font-size:14.5px; padding:13px 32px; border-radius:var(--radius-sm); box-shadow:0 4px 16px rgba(184,150,78,0.35); display:inline-flex; align-items:center; gap:8px; text-decoration:none; transition:all 0.2s; cursor:pointer; }
    .btn-gold-lg:hover { box-shadow:0 6px 24px rgba(184,150,78,0.45); transform:translateY(-1px); color:var(--navy); }

    @@keyframes fadeUp { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }
    .anim-1 { animation:fadeUp 0.45s ease 0.05s both; }
    .anim-2 { animation:fadeUp 0.45s ease 0.12s both; }
    .anim-3 { animation:fadeUp 0.45s ease 0.19s both; }
    .anim-4 { animation:fadeUp 0.45s ease 0.26s both; }

    @@media (max-width:860px)  { .plan-grid { grid-template-columns:1fr; } .plan-card.featured { transform:none; } }
    @@media (max-width:576px)  { .plans-hero h1 { font-size:1.7rem; } .plans-hero { padding:36px 18px 32px; } }
</style>
}

<!-- Hero -->
<div class="plans-hero anim-1">
    <div class="plans-hero-tag"><i class="bi bi-stars"></i>Gói dịch vụ</div>
    <h1>Chọn gói phù hợp với<br><span>doanh nghiệp</span> của bạn</h1>
    <p>Bắt đầu miễn phí và nâng cấp bất cứ lúc nào. Không phí ẩn, không ràng buộc.</p>
</div>

<!-- Error -->
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="border-radius:var(--radius-sm);font-size:13.5px;">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Plan Cards -->
<div class="plan-grid anim-2">

    <!-- FREE -->
    @{
        bool freeHighlight  = highlight == "Free";
        bool basicHighlight = highlight == "Basic";
        bool proHighlight   = highlight == "Pro";
    }
    <div class="plan-card @(freeHighlight ? "featured" : "")">
        @if (freeHighlight) { <div class="plan-ribbon">Phổ biến</div> }
        <div class="plan-header">
            <div class="plan-icon free"><i class="bi bi-gift"></i></div>
            <div class="plan-name">Free</div>
            <div class="plan-tagline">Khởi đầu không tốn phí. Phù hợp để thử nghiệm.</div>
            <div class="plan-price-wrap">
                <div class="plan-price free-price">0 ₫</div>
                <div class="plan-price-unit">/ mãi mãi</div>
            </div>
        </div>
        <hr class="plan-divider" />
        <div class="plan-features">
            <ul class="plan-feature-list">
                <li><i class="bi bi-check-circle-fill check"></i><span><span class="feature-strong">1 quầy</span> (stall)</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Quản lý nội dung cơ bản</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Vị trí bản đồ</span></li>
                <li><i class="bi bi-dash-circle dash"></i><span>Thuyết minh âm thanh (TTS)</span></li>
                <li><i class="bi bi-dash-circle dash"></i><span>Đa ngôn ngữ nâng cao</span></li>
                <li><i class="bi bi-dash-circle dash"></i><span>Hỗ trợ ưu tiên</span></li>
            </ul>
        </div>
        <div class="plan-footer">
            @if (!Model.IsLoggedIn)
            {
                <a asp-controller="Auth" asp-action="Register" class="btn-plan outline">
                    <i class="bi bi-person-plus"></i>Đăng ký miễn phí
                </a>
            }
            else
            {
                <div class="btn-plan current"><i class="bi bi-check2"></i>Gói hiện tại</div>
            }
        </div>
    </div>

    <!-- BASIC -->
    <div class="plan-card @(basicHighlight ? "featured" : "")">
        @if (basicHighlight) { <div class="plan-ribbon">Phổ biến</div> }
        <div class="plan-header">
            <div class="plan-icon basic"><i class="bi bi-shield-check"></i></div>
            <div class="plan-name">Basic</div>
            <div class="plan-tagline">Giải pháp hoàn hảo cho doanh nghiệp vừa và nhỏ.</div>
            <div class="plan-price-wrap">
                <div class="plan-price">199.000 ₫</div>
                <div class="plan-price-unit">/ tháng</div>
            </div>
        </div>
        <hr class="plan-divider" />
        <div class="plan-features">
            <ul class="plan-feature-list">
                <li><i class="bi bi-check-circle-fill check"></i><span>Tất cả tính năng Free</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span><span class="feature-strong">3 quầy</span> (stalls)</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Thuyết minh âm thanh <span class="feature-strong">(TTS)</span></span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Đa ngôn ngữ nâng cao</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Hỗ trợ tiêu chuẩn</span></li>
                <li><i class="bi bi-dash-circle dash"></i><span>Phân tích nâng cao</span></li>
            </ul>
        </div>
        <div class="plan-footer">
            @if (!Model.IsLoggedIn)
            {
                <a asp-controller="Auth" asp-action="Login"
                   asp-route-returnUrl="@Url.Action("Checkout","Subscription",new{plan="Basic"})"
                   class="btn-plan @(basicHighlight ? "gold" : "navy")">
                    <i class="bi bi-box-arrow-in-right"></i>Đăng nhập để mua
                </a>
            }
            else if (!Model.HasBusiness)
            {
                <a asp-controller="Business" asp-action="Index" class="btn-plan navy">
                    <i class="bi bi-building-add"></i>Tạo business trước
                </a>
                <div class="btn-plan-note">Cần có business để đăng ký gói</div>
            }
            else
            {
                <a asp-controller="Subscription" asp-action="Checkout"
                   asp-route-plan="Basic"
                   asp-route-businessId="@Model.PreselectedBusinessId"
                   class="btn-plan @(basicHighlight ? "gold" : "navy")">
                    <i class="bi bi-credit-card"></i>Chọn gói Basic
                </a>
            }
        </div>
    </div>

    <!-- PRO -->
    <div class="plan-card @(proHighlight ? "featured" : "")">
        @if (proHighlight) { <div class="plan-ribbon">Phổ biến</div> }
        <div class="plan-header">
            <div class="plan-icon pro"><i class="bi bi-star-fill"></i></div>
            <div class="plan-name">Pro</div>
            <div class="plan-tagline">Toàn bộ tính năng cho doanh nghiệp lớn và chuỗi.</div>
            <div class="plan-price-wrap">
                <div class="plan-price">499.000 ₫</div>
                <div class="plan-price-unit">/ tháng</div>
            </div>
        </div>
        <hr class="plan-divider" />
        <div class="plan-features">
            <ul class="plan-feature-list">
                <li><i class="bi bi-check-circle-fill check"></i><span>Tất cả tính năng Basic</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span><span class="feature-strong">Không giới hạn</span> quầy (stalls)</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Thuyết minh âm thanh <span class="feature-strong">(TTS)</span></span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Phân tích nâng cao</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Hỗ trợ ưu tiên 24/7</span></li>
                <li><i class="bi bi-check-circle-fill check"></i><span>Xuất báo cáo</span></li>
            </ul>
        </div>
        <div class="plan-footer">
            @if (!Model.IsLoggedIn)
            {
                <a asp-controller="Auth" asp-action="Login"
                   asp-route-returnUrl="@Url.Action("Checkout","Subscription",new{plan="Pro"})"
                   class="btn-plan @(proHighlight ? "gold" : "navy")">
                    <i class="bi bi-box-arrow-in-right"></i>Đăng nhập để mua
                </a>
            }
            else if (!Model.HasBusiness)
            {
                <a asp-controller="Business" asp-action="Index" class="btn-plan navy">
                    <i class="bi bi-building-add"></i>Tạo business trước
                </a>
                <div class="btn-plan-note">Cần có business để đăng ký gói</div>
            }
            else
            {
                <a asp-controller="Subscription" asp-action="Checkout"
                   asp-route-plan="Pro"
                   asp-route-businessId="@Model.PreselectedBusinessId"
                   class="btn-plan @(proHighlight ? "gold" : "navy")">
                    <i class="bi bi-credit-card"></i>Chọn gói Pro
                </a>
            }
        </div>
    </div>

</div>

<!-- Comparison Table -->
<div class="compare-section anim-3">
    <div class="compare-title">So sánh chi tiết các gói</div>
    <div class="compare-sub">Chọn gói phù hợp nhất với nhu cầu của bạn</div>
    <div class="compare-card">
        <div class="table-responsive">
            <table class="table compare-table mb-0">
                <thead>
                    <tr>
                        <th style="width:38%;">Tính năng</th>
                        <th>Free</th>
                        <th class="@(basicHighlight ? "featured-col" : "")">Basic</th>
                        <th class="@(proHighlight ? "featured-col" : "")">Pro</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="group-header"><td colspan="4">Quầy & Nội dung</td></tr>
                    <tr>
                        <td>Số quầy (stalls) tối đa</td>
                        <td><span class="val">1</span></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><span class="val">3</span></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><span class="val">Không giới hạn</span></td>
                    </tr>
                    <tr>
                        <td>Quản lý nội dung cơ bản</td>
                        <td><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                    </tr>
                    <tr>
                        <td>Vị trí bản đồ</td>
                        <td><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                    </tr>
                    <tr class="group-header"><td colspan="4">Âm thanh & Ngôn ngữ</td></tr>
                    <tr>
                        <td>Thuyết minh âm thanh (TTS)</td>
                        <td><i class="bi bi-x-circle-fill cross"></i></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                    </tr>
                    <tr>
                        <td>Đa ngôn ngữ nâng cao</td>
                        <td><i class="bi bi-x-circle-fill cross"></i></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                    </tr>
                    <tr class="group-header"><td colspan="4">Phân tích & Hỗ trợ</td></tr>
                    <tr>
                        <td>Thống kê cơ bản</td>
                        <td><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                    </tr>
                    <tr>
                        <td>Phân tích nâng cao</td>
                        <td><i class="bi bi-x-circle-fill cross"></i></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><i class="bi bi-x-circle-fill cross"></i></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                    </tr>
                    <tr>
                        <td>Xuất báo cáo</td>
                        <td><i class="bi bi-x-circle-fill cross"></i></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><i class="bi bi-x-circle-fill cross"></i></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><i class="bi bi-check-circle-fill tick"></i></td>
                    </tr>
                    <tr>
                        <td>Hỗ trợ kỹ thuật</td>
                        <td><span style="font-size:13px;color:var(--text-light);">Email</span></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><span class="val">Tiêu chuẩn</span></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><span class="val" style="color:#3a7d4f;">Ưu tiên 24/7</span></td>
                    </tr>
                    <tr class="group-header"><td colspan="4">Giá</td></tr>
                    <tr>
                        <td>Giá / tháng</td>
                        <td><span class="val">0 ₫</span></td>
                        <td class="@(basicHighlight ? "featured-col" : "")"><span class="val">199.000 ₫</span></td>
                        <td class="@(proHighlight ? "featured-col" : "")"><span class="val">499.000 ₫</span></td>
                    </tr>
                    <tr>
                        <td></td>
                        <td></td>
                        <td class="@(basicHighlight ? "featured-col" : "")" style="padding-bottom:16px;">
                            @if (Model.IsLoggedIn && Model.HasBusiness)
                            {
                                <a asp-controller="Subscription" asp-action="Checkout" asp-route-plan="Basic"
                                   asp-route-businessId="@Model.PreselectedBusinessId"
                                   class="btn-plan @(basicHighlight ? "gold" : "navy")" style="padding:8px 16px;font-size:13px;">
                                    Mua Basic
                                </a>
                            }
                        </td>
                        <td class="@(proHighlight ? "featured-col" : "")" style="padding-bottom:16px;">
                            @if (Model.IsLoggedIn && Model.HasBusiness)
                            {
                                <a asp-controller="Subscription" asp-action="Checkout" asp-route-plan="Pro"
                                   asp-route-businessId="@Model.PreselectedBusinessId"
                                   class="btn-plan @(proHighlight ? "gold" : "navy")" style="padding:8px 16px;font-size:13px;">
                                    Mua Pro
                                </a>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- FAQ -->
<div class="faq-section anim-4">
    <div class="faq-title">Câu hỏi thường gặp</div>
    <div class="faq-sub">Những thắc mắc phổ biến về gói dịch vụ</div>
    <div class="accordion" id="faqAccordion">

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                    Tôi có thể nâng cấp hoặc hạ gói bất cứ lúc nào không?
                </button>
            </h2>
            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    Bạn có thể nâng cấp lên gói cao hơn bất cứ lúc nào. Khi nâng cấp trong thời gian gói cũ còn hạn, thời hạn mới sẽ được <strong>cộng dồn</strong> từ ngày hết hạn gói cũ. Tuy nhiên, bạn không thể hạ gói khi gói hiện tại vẫn còn hiệu lực — hãy chờ đến khi hết hạn.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                    Thanh toán có an toàn không?
                </button>
            </h2>
            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    Hệ thống hiện tại đang hoạt động ở chế độ <strong>thử nghiệm (mock payment)</strong>. Thẻ thật sẽ không bị trừ tiền. Để thanh toán thành công, sử dụng số thẻ <code>4111 1111 1111 1111</code> với bất kỳ ngày hết hạn và CVV hợp lệ.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                    Gói kích hoạt ngay sau khi thanh toán không?
                </button>
            </h2>
            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    Có. Ngay sau khi thanh toán thành công, gói dịch vụ được kích hoạt tức thì và bạn có thể sử dụng đầy đủ tính năng ngay lập tức. Không cần chờ duyệt.
                </div>
            </div>
        </div>

        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                    Một tài khoản có thể quản lý nhiều business không?
                </button>
            </h2>
            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                <div class="accordion-body">
                    Có. Một tài khoản <strong>BusinessOwner</strong> có thể quản lý nhiều business. Mỗi business có gói và hạn sử dụng riêng biệt. Khi đăng ký gói, bạn chọn business nào cần được kích hoạt.
                </div>
            </div>
        </div>

    </div>
</div>

<!-- CTA Bottom -->
@if (!Model.IsLoggedIn)
{
    <div class="cta-bottom anim-4">
        <h2>Bắt đầu ngay hôm nay</h2>
        <p>Tạo tài khoản miễn phí và trải nghiệm hệ thống quản lý chợ hiện đại nhất.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Auth" asp-action="Register" class="btn-gold-lg">
                <i class="bi bi-person-plus"></i>Tạo tài khoản miễn phí
            </a>
            <a asp-controller="Auth" asp-action="Login" class="btn-gold-lg"
               style="background:rgba(247,243,237,0.12);color:var(--cream);box-shadow:none;border:1px solid rgba(247,243,237,0.25);">
                <i class="bi bi-box-arrow-in-right"></i>Đăng nhập
            </a>
        </div>
    </div>
}
