@model Web.Models.StallManagementViewModel
@{
    ViewData["Title"] = "Stall Management";
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
    var businessLookup = Model.Businesses.ToDictionary(b => b.Id, b => b.Name);
    var activeCount = Model.Items.Count(x => x.IsActive);
    var inactiveCount = Model.Items.Count(x => !x.IsActive);
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed;
        --cream-dark: #ede8df;
        --ivory: #faf8f4;
        --navy: #1e2d40;
        --navy-mid: #2c3e55;
        --gold: #b8964e;
        --gold-light: #d4ae6a;
        --gold-pale: #f0e4c8;
        --text-dark: #1e2d40;
        --text-mid: #4a5568;
        --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --shadow-lg: 0 8px 32px rgba(30,45,64,0.13);
        --radius: 10px;
        --radius-sm: 6px;
        --status-occupied: #3d7a8a;
        --status-available: #4a7c59;
        --status-maintenance: #a2493a;
    }

    /* ── BREADCRUMB ── */
    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

    /* ── PAGE HEADER ── */
    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius);
        padding: 32px 40px;
        margin-bottom: 28px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 20px;
        box-shadow: var(--shadow-md);
        position: relative; overflow: hidden;
    }
    .page-header::before {
        content: '';
        position: absolute; top: -20px; right: -20px;
        width: 160px; height: 160px; border-radius: 50%;
        background: rgba(184,150,78,0.08); pointer-events: none;
    }
    .page-header-content { position: relative; z-index: 1; }
    .page-header-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem; font-weight: 700;
        color: var(--cream); margin: 0 0 8px;
        display: flex; align-items: center; gap: 12px;
    }
    .page-header-title i { color: var(--gold-light); }
    .page-header-lead {
        font-size: 14px; color: rgba(247,243,237,0.7);
        margin: 0;
    }
    .page-header-actions { display: flex; gap: 10px; flex-wrap: wrap; position: relative; z-index: 1; }
    .btn-gold {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        color: var(--navy); border: none; font-weight: 600;
        font-size: 13.5px; padding: 10px 24px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        box-shadow: 0 2px 10px rgba(184,150,78,0.3);
        display: inline-flex; align-items: center; gap: 8px; cursor: pointer;
    }
    .btn-gold:hover { color: var(--navy); box-shadow: 0 4px 16px rgba(184,150,78,0.4); transform: translateY(-1px); }
    .btn-ghost-cream {
        background: rgba(247,243,237,0.1); color: var(--cream);
        border: 1px solid rgba(247,243,237,0.25);
        font-weight: 500; font-size: 13.5px; padding: 10px 20px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
    }
    .btn-ghost-cream:hover { background: rgba(247,243,237,0.18); color: var(--cream); border-color: rgba(247,243,237,0.45); }

    /* ── ALERT ── */
    .alert-success-custom { background: rgba(74,124,89,0.08); border: 1px solid rgba(74,124,89,0.2); border-radius: var(--radius-sm); color: #3a7d4f; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .alert-error-custom { background: rgba(162,73,58,0.08); border: 1px solid rgba(162,73,58,0.2); border-radius: var(--radius-sm); color: #a2493a; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }

    /* ── STAT CARDS ── */
    .stat-card {
        background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 20px 22px; box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
        transition: box-shadow 0.2s, transform 0.2s;
    }
    .stat-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .stat-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; border-radius: 4px 0 0 4px; }
    .stat-card-navy::before { background: var(--navy); }
    .stat-card-green::before { background: var(--status-available); }
    .stat-card-red::before { background: var(--status-maintenance); }
    .stat-card-number { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: var(--text-dark); line-height: 1; margin-bottom: 4px; }
    .stat-card-label { font-size: 11.5px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-light); }

    /* ── CARD ── */
    .card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 24px; }
    .card-body { padding: 20px 24px; }
    .card-footer { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 14px 20px; }

    /* ── FILTER FORM ── */
    .search-box { position: relative; }
    .search-box-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 14px; }
    .search-box .form-control { padding-left: 36px; }
    .form-control, .form-select {
        border: 1px solid var(--border); border-radius: var(--radius-sm);
        padding: 9px 13px; font-size: 14px; color: var(--text-dark);
        background: #fff; transition: all 0.2s ease; outline: none;
    }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.12); }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 5px; }
    textarea.form-control { resize: vertical; }
    .btn-classic {
        display: inline-flex; align-items: center; gap: 5px;
        font-size: 13px; font-weight: 600; padding: 9px 18px;
        border-radius: var(--radius-sm); border: 1.5px solid; cursor: pointer;
        transition: all 0.18s ease; background: transparent; text-decoration: none;
    }
    .btn-classic-navy { border-color: var(--navy); color: var(--navy); }
    .btn-classic-navy:hover { background: var(--navy); color: var(--cream); }
    .btn-classic-outline { border-color: var(--border); color: var(--text-mid); }
    .btn-classic-outline:hover { border-color: var(--gold); color: var(--gold); }

    /* ── TABLE ── */
    .table { margin: 0; font-size: 14px; }
    .table thead { background: var(--cream-dark); }
    .table thead th { font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); border-bottom: 2px solid var(--border); padding: 14px 16px; white-space: nowrap; }
    .table tbody td { padding: 14px 16px; vertical-align: middle; border-bottom: 1px solid var(--border); color: var(--text-dark); }
    .table tbody tr { background: #fff; transition: all 0.15s ease; }
    .table tbody tr:hover { background: var(--cream); }
    .table tbody tr:last-child td { border-bottom: none; }
    .stall-name-cell { font-weight: 600; color: var(--text-dark); }
    .stall-name-cell small { font-weight: 400; color: var(--text-light); font-size: 11.5px; }
    .badge-active { background: rgba(74,124,89,0.12); color: #3a7d4f; border: 1px solid rgba(74,124,89,0.25); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-inactive { background: rgba(162,73,58,0.1); color: #a2493a; border: 1px solid rgba(162,73,58,0.2); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .btn-action { width: 30px; height: 30px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: var(--radius-sm); font-size: 14px; border: 1.5px solid; cursor: pointer; transition: all 0.15s ease; background: transparent; margin-right: 4px; }
    .btn-action-edit { border-color: var(--navy); color: var(--navy); }
    .btn-action-edit:hover { background: var(--navy); color: var(--cream); }
    .btn-action-view { border-color: var(--status-occupied); color: var(--status-occupied); }
    .btn-action-view:hover { background: var(--status-occupied); color: #fff; }
    .btn-action-deact { border-color: var(--status-maintenance); color: var(--status-maintenance); }
    .btn-action-deact:hover { background: var(--status-maintenance); color: #fff; }

    /* ── PAGINATION ── */
    .pagination .page-link { border: 1px solid var(--border); color: var(--text-dark); padding: 6px 12px; font-size: 13px; border-radius: var(--radius-sm); transition: all 0.18s ease; }
    .pagination .page-link:hover { background: var(--gold-pale); border-color: var(--gold); color: var(--navy); }
    .pagination .page-item.active .page-link { background: var(--gold); border-color: var(--gold); color: var(--navy); font-weight: 600; }
    .pagination .page-item.disabled .page-link { background: var(--cream); border-color: var(--border); color: var(--text-light); }

    /* ── MODAL ── */
    .modal-content { border: none; border-radius: var(--radius); box-shadow: var(--shadow-lg); }
    .modal-header { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%); border-bottom: none; border-radius: var(--radius) var(--radius) 0 0; padding: 20px 24px; }
    .modal-header .modal-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--cream); display: flex; align-items: center; gap: 10px; }
    .modal-header .modal-title i { color: var(--gold-light); }
    .modal-header .btn-close { filter: brightness(0) invert(1); opacity: 0.7; }
    .modal-header .btn-close:hover { opacity: 1; }
    .modal-body { padding: 28px 24px; background: var(--ivory); }
    .modal-footer { background: var(--cream-dark); border-top: 1px solid var(--border); border-radius: 0 0 var(--radius) var(--radius); padding: 16px 24px; }
    .is-invalid { border-color: #a2493a !important; }
    .field-validation-error, .text-danger { color: #a2493a; font-size: 12px; margin-top: 4px; display: block; }
    .detail-row { display: flex; padding: 10px 0; border-bottom: 1px solid var(--border); gap: 12px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { font-size: 13px; font-weight: 600; color: var(--text-mid); min-width: 130px; }
    .detail-value { font-size: 14px; color: var(--text-dark); }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .anim-1 { animation: fadeUp 0.45s ease 0.08s both; }
    .anim-2 { animation: fadeUp 0.45s ease 0.15s both; }
    .anim-3 { animation: fadeUp 0.45s ease 0.22s both; }

    @@media (max-width: 576px) {
        .page-header { padding: 24px 20px; }
        .page-header-title { font-size: 1.5rem; }
        .page-header-actions { width: 100%; }
    }
    .validation-summary-valid { display: none !important; }
</style>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Management</a></li>
        <li class="breadcrumb-item active" aria-current="page">Stall Management</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-header-title">
            <i class="bi bi-shop-window" aria-hidden="true"></i>Stall Management
        </h1>
        <p class="page-header-lead">Manage stall allocations, rentals, and availability.</p>
    </div>
    <div class="page-header-actions">
        <a asp-controller="StallLocation" asp-action="Index" class="btn-ghost-cream">
            <i class="bi bi-map" aria-hidden="true"></i>View Map
        </a>
        <button type="button" class="btn-gold" data-bs-toggle="modal" data-bs-target="#addStallModal">
            <i class="bi bi-plus-circle" aria-hidden="true"></i>Add New Stall
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert-success-custom">
        <i class="bi bi-check-circle-fill"></i>@Model.SuccessMessage
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-error-custom">
        <i class="bi bi-exclamation-circle-fill"></i>@Model.ErrorMessage
    </div>
}

<!-- Stats -->
<section class="mb-4 anim-1" aria-label="Statistics">
    <div class="row g-3">
        <div class="col-sm-4">
            <div class="stat-card stat-card-navy">
                <div class="stat-card-number">@Model.TotalCount</div>
                <div class="stat-card-label">Total Stalls</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="stat-card stat-card-green">
                <div class="stat-card-number">@activeCount</div>
                <div class="stat-card-label">Active (This Page)</div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="stat-card stat-card-red">
                <div class="stat-card-number">@inactiveCount</div>
                <div class="stat-card-label">Inactive (This Page)</div>
            </div>
        </div>
    </div>
</section>

<!-- Filters -->
<div class="card anim-2">
    <div class="card-body">
        <form class="row g-3" method="get" asp-action="Index" asp-controller="Stall">
            <div class="col-md-4">
                <label for="searchStall" class="form-label">Search Stalls</label>
                <div class="search-box">
                    <i class="bi bi-search search-box-icon"></i>
                    <input type="text" class="form-control" id="searchStall" name="search"
                           value="@Model.Search" placeholder="Search by name or slug...">
                </div>
            </div>
            <div class="col-md-4">
                <label for="businessFilter" class="form-label">Filter by Business</label>
                <select class="form-select" id="businessFilter" name="businessId">
                    <option value="">All Businesses</option>
                    @foreach (var business in Model.Businesses)
                    {
                        <option value="@business.Id" selected="@(Model.BusinessId == business.Id)">@business.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn-classic btn-classic-navy">
                    <i class="bi bi-funnel"></i>Filter
                </button>
                <a asp-action="Index" asp-controller="Stall" class="btn-classic btn-classic-outline">
                    <i class="bi bi-x-circle"></i>Clear
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Stall Table -->
<div class="card anim-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table" id="stallTable" aria-label="Stall list">
                <thead>
                    <tr>
                        <th scope="col">Stall Name</th>
                        <th scope="col">Slug</th>
                        <th scope="col">Business</th>
                        <th scope="col">Status</th>
                        <th scope="col">Contact</th>
                        <th scope="col">Created At</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No stalls found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var stall in Model.Items)
                        {
                            var businessName = businessLookup.TryGetValue(stall.BusinessId, out var bname) ? bname : stall.BusinessId.ToString();
                            <tr>
                                <td>
                                    <div class="stall-name-cell">
                                        @stall.Name
                                        <small class="d-block">ID: @stall.Id.ToString()[..8]…</small>
                                    </div>
                                </td>
                                <td><code style="font-size:12px;color:var(--text-mid)">@stall.Slug</code></td>
                                <td><span style="color:var(--gold);font-weight:500">@businessName</span></td>
                                <td>
                                    @if (stall.IsActive)
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(stall.ContactEmail))
                                    {
                                        <div style="font-size:13px">@stall.ContactEmail</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(stall.ContactPhone))
                                    {
                                        <div style="font-size:12px;color:var(--text-light)">@stall.ContactPhone</div>
                                    }
                                    @if (string.IsNullOrWhiteSpace(stall.ContactEmail) && string.IsNullOrWhiteSpace(stall.ContactPhone))
                                    {
                                        <span style="color:var(--text-light);font-size:12px">—</span>
                                    }
                                </td>
                                <td style="font-size:12.5px;color:var(--text-light)">@stall.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <button type="button" class="btn-action btn-action-edit"
                                            data-bs-toggle="tooltip" title="Edit"
                                            data-id="@stall.Id"
                                            data-businessid="@stall.BusinessId"
                                            data-name="@stall.Name"
                                            data-slug="@stall.Slug"
                                            data-description="@stall.Description"
                                            data-email="@stall.ContactEmail"
                                            data-phone="@stall.ContactPhone"
                                            data-active="@stall.IsActive.ToString().ToLower()"
                                            onclick="openEditModal(this)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn-action btn-action-view"
                                            data-bs-toggle="tooltip" title="View Details"
                                            data-id="@stall.Id"
                                            data-businessid="@stall.BusinessId"
                                            data-businessname="@businessName"
                                            data-name="@stall.Name"
                                            data-slug="@stall.Slug"
                                            data-description="@stall.Description"
                                            data-email="@stall.ContactEmail"
                                            data-phone="@stall.ContactPhone"
                                            data-active="@stall.IsActive.ToString().ToLower()"
                                            data-created="@stall.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                            data-updated="@(stall.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")"
                                            onclick="openShowModal(this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <form asp-action="Deactivate" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@stall.Id" />
                                        <input type="hidden" name="page" value="@Model.Page" />
                                        <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                        <input type="hidden" name="search" value="@Model.Search" />
                                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                        <button type="submit" class="btn-action btn-action-deact"
                                                data-bs-toggle="tooltip" title="Deactivate"
                                                onclick="return confirm('Deactivate this stall?')">
                                            <i class="bi bi-slash-circle"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span style="font-size:13px;color:var(--text-light)">
            Showing @startIndex–@endIndex of @Model.TotalCount stalls
        </span>
        <nav aria-label="Stall list pagination">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-businessId="@Model.BusinessId">‹ Prev</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-businessId="@Model.BusinessId">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-businessId="@Model.BusinessId">Next ›</a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Add Stall Modal -->
<div class="modal fade" id="addStallModal" tabindex="-1" aria-labelledby="addStallModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addStallModalLabel">
                    <i class="bi bi-shop-window"></i>Add New Stall
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <input type="hidden" name="search" value="@Model.Search" />
                <input type="hidden" name="businessId" value="@Model.BusinessId" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert-error-custom mb-3"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Create.BusinessId" class="form-label">Business <span style="color:#a2493a">*</span></label>
                            <select asp-for="Create.BusinessId" class="form-select @(ViewData.ModelState["Create.BusinessId"]?.Errors.Count > 0 ? "is-invalid" : "")" id="createBusinessId">
                                <option value="">— Select Business —</option>
                                @foreach (var business in Model.Businesses)
                                {
                                    <option value="@business.Id">@business.Name</option>
                                }
                            </select>
                            <span asp-validation-for="Create.BusinessId" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Create.Name" class="form-label">Stall Name <span style="color:#a2493a">*</span></label>
