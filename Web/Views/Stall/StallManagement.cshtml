        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editStallModalLabel">
                    <i class="bi bi-pencil-square"></i>Edit Stall
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <input type="hidden" name="search" value="@Model.Search" />
                <input type="hidden" name="businessId" value="@Model.BusinessId" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert-error-custom mb-3"></div>
                    <input asp-for="Edit.Id" type="hidden" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.BusinessId" class="form-label">Business <span style="color:#a2493a">*</span></label>
                            <select asp-for="Edit.BusinessId" class="form-select @(ViewData.ModelState["Edit.BusinessId"]?.Errors.Count > 0 ? "is-invalid" : "")" id="editBusinessId">
