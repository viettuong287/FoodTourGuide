                                @foreach (var business in Model.Businesses)
                                {
                                    <option value="@business.Id">@business.Name</option>
                                }
                            </select>
                            <span asp-validation-for="Edit.BusinessId" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.Name" class="form-label">Stall Name <span style="color:#a2493a">*</span></label>
                            <input asp-for="Edit.Name" class="form-control @(ViewData.ModelState["Edit.Name"]?.Errors.Count > 0 ? "is-invalid" : "")" id="editStallName" placeholder="Enter stall name" />
                            <span asp-validation-for="Edit.Name" class="field-validation-error"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.Slug" class="form-label">Slug <span style="color:#a2493a">*</span></label>
                            <input asp-for="Edit.Slug" class="form-control @(ViewData.ModelState["Edit.Slug"]?.Errors.Count > 0 ? "is-invalid" : "")" id="editStallSlug" placeholder="stall-slug" />
                            <span asp-validation-for="Edit.Slug" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.ContactEmail" class="form-label">Contact Email</label>
                            <input asp-for="Edit.ContactEmail" class="form-control @(ViewData.ModelState["Edit.ContactEmail"]?.Errors.Count > 0 ? "is-invalid" : "")" id="editContactEmail" placeholder="email@domain.com" />
                            <span asp-validation-for="Edit.ContactEmail" class="field-validation-error"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.ContactPhone" class="form-label">Contact Phone</label>
                            <input asp-for="Edit.ContactPhone" class="form-control @(ViewData.ModelState["Edit.ContactPhone"]?.Errors.Count > 0 ? "is-invalid" : "")" id="editContactPhone" placeholder="0123456789" />
                            <span asp-validation-for="Edit.ContactPhone" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.IsActive" class="form-label">Status</label>
                            <select asp-for="Edit.IsActive" class="form-select" id="editStallStatus">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
