        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="showStallModal" tabindex="-1" aria-labelledby="showStallModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="showStallModalLabel">
                    <i class="bi bi-eye"></i>Stall Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="detail-row"><span class="detail-label">Stall Name</span><span class="detail-value" id="showStallName">-</span></div>
                <div class="detail-row"><span class="detail-label">ID</span><span class="detail-value" id="showStallId">-</span></div>
                <div class="detail-row"><span class="detail-label">Business</span><span class="detail-value" id="showBusiness">-</span></div>
                <div class="detail-row"><span class="detail-label">Slug</span><span class="detail-value" id="showSlug">-</span></div>
                <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value" id="showStatus">-</span></div>
                <div class="detail-row"><span class="detail-label">Contact Email</span><span class="detail-value" id="showContactEmail">-</span></div>
                <div class="detail-row"><span class="detail-label">Contact Phone</span><span class="detail-value" id="showContactPhone">-</span></div>
                <div class="detail-row"><span class="detail-label">Created At</span><span class="detail-value" id="showCreatedAt">-</span></div>
                <div class="detail-row"><span class="detail-label">Updated At</span><span class="detail-value" id="showUpdatedAt">-</span></div>
                <div class="detail-row"><span class="detail-label">Description</span><span class="detail-value" id="showDescription">-</span></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    const slugify = (text) => {
        if (!text) return '';
        return text.toLowerCase().trim()
            .replace(/\s+/g, '-')
            .replace(/[^a-z0-9-]/g, '')
            .replace(/-+/g, '-')
            .replace(/^-|-$/g, '');
    };

    const bindSlug = (nameId, slugId) => {
        const nameEl = document.getElementById(nameId);
        const slugEl = document.getElementById(slugId);
        if (!nameEl || !slugEl) return;
        nameEl.addEventListener('input', function () {
            if (!slugEl.dataset.manual) {
                slugEl.value = slugify(this.value);
            }
        });
        slugEl.addEventListener('input', function () {
            this.dataset.manual = '1';
        });
    };

    function openEditModal(btn) {
        document.getElementById('editBusinessId').value = btn.dataset.businessid || '';
        document.getElementById('editStallName').value = btn.dataset.name || '';
        const slugEl = document.getElementById('editStallSlug');
        slugEl.value = btn.dataset.slug || '';
        slugEl.dataset.manual = '1';
        document.getElementById('editContactEmail').value = btn.dataset.email || '';
        document.getElementById('editContactPhone').value = btn.dataset.phone || '';
        document.getElementById('editStallStatus').value = btn.dataset.active || 'true';
        document.getElementById('editDescription').value = btn.dataset.description || '';
        document.querySelector('input[name="Edit.Id"]').value = btn.dataset.id || '';
        new bootstrap.Modal(document.getElementById('editStallModal')).show();
    }

    function openShowModal(btn) {
        const isActive = btn.dataset.active === 'true';
        document.getElementById('showStallName').textContent = btn.dataset.name || '-';
        document.getElementById('showStallId').textContent = btn.dataset.id || '-';
        document.getElementById('showBusiness').textContent = btn.dataset.businessname || btn.dataset.businessid || '-';
        document.getElementById('showStatus').innerHTML = isActive
            ? '<span class="badge-active">Active</span>'
            : '<span class="badge-inactive">Inactive</span>';
        document.getElementById('showSlug').textContent = btn.dataset.slug || '-';
        document.getElementById('showContactEmail').textContent = btn.dataset.email || '-';
        document.getElementById('showContactPhone').textContent = btn.dataset.phone || '-';
        document.getElementById('showCreatedAt').textContent = btn.dataset.created || '-';
        document.getElementById('showUpdatedAt').textContent = btn.dataset.updated || '-';
        document.getElementById('showDescription').textContent = btn.dataset.description || '-';
        new bootstrap.Modal(document.getElementById('showStallModal')).show();
    }

    $(document).ready(function () {
        bindSlug('createStallName', 'createStallSlug');
        bindSlug('editStallName', 'editStallSlug');

        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));

        @if (Model.ShowCreateModal)
        {
            <text>new bootstrap.Modal(document.getElementById('addStallModal')).show();</text>
        }
        @if (Model.ShowEditModal)
        {
            <text>new bootstrap.Modal(document.getElementById('editStallModal')).show();</text>
        }
    });
</script>
}
