@model Web.Models.BusinessManagementViewModel
@{
    ViewData["Title"] = "Business Management";
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed; --cream-dark: #ede8df; --ivory: #faf8f4;
        --navy: #1e2d40; --navy-mid: #2c3e55; --navy-light: #3d5068;
        --gold: #b8964e; --gold-light: #d4ae6a; --gold-pale: #f0e4c8;
        --text-dark: #1e2d40; --text-mid: #4a5568; --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --shadow-lg: 0 8px 32px rgba(30,45,64,0.13);
        --radius: 10px; --radius-sm: 6px;
    }
    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }
    .page-header { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%); border-radius: var(--radius); padding: 32px 40px; margin-bottom: 28px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; box-shadow: var(--shadow-md); position: relative; overflow: hidden; }
    .page-header::before { content: ''; position: absolute; top: -20px; right: -20px; width: 160px; height: 160px; border-radius: 50%; background: rgba(184,150,78,0.08); pointer-events: none; }
    .page-header-content { position: relative; z-index: 1; }
    .page-header h1 { font-size: 2rem; font-weight: 700; color: var(--cream); margin: 0 0 8px; display: flex; align-items: center; gap: 12px; }
    .page-header h1 i { color: var(--gold-light); }
    .page-header .lead { font-size: 14px; color: rgba(247,243,237,0.7); margin: 0; font-style: italic; }
    .page-header-actions { position: relative; z-index: 1; }
    .btn-gold { background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: var(--navy); border: none; font-weight: 600; font-size: 13.5px; padding: 10px 24px; border-radius: var(--radius-sm); transition: all 0.2s ease; box-shadow: 0 2px 10px rgba(184,150,78,0.3); display: inline-flex; align-items: center; gap: 8px; cursor: pointer; }
    .btn-gold:hover { color: var(--navy); box-shadow: 0 4px 16px rgba(184,150,78,0.4); transform: translateY(-1px); }
    .btn-classic { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 600; letter-spacing: 0.03em; padding: 6px 13px; border-radius: var(--radius-sm); border: 1.5px solid; text-decoration: none; transition: all 0.18s ease; background: transparent; white-space: nowrap; cursor: pointer; }
    .btn-classic.navy { border-color: var(--navy); color: var(--navy); }
    .btn-classic.navy:hover { background: var(--navy); color: var(--cream); }
    .card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); margin-bottom: 24px; }
    .card-header { background: var(--cream-dark); border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; }
    .card-body { padding: 24px; }
    .card-footer { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 14px 24px; }
    .search-box { position: relative; }
    .search-box .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-size: 14px; pointer-events: none; }
    .search-box .form-control { padding-left: 38px; }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 6px; }
    .form-control, .form-select { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 9px 14px; font-size: 14px; color: var(--text-dark); background: #fff; transition: all 0.2s ease; }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.1); outline: none; }
    .table { margin: 0; font-size: 14px; }
    .table thead { background: var(--cream-dark); }
    .table thead th { font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); border-bottom: 2px solid var(--border); padding: 14px 16px; white-space: nowrap; }
    .table tbody td { padding: 16px; vertical-align: middle; border-bottom: 1px solid var(--border); color: var(--text-dark); }
    .table tbody tr { background: #fff; transition: all 0.2s ease; }
    .table tbody tr:hover { background: var(--cream); box-shadow: var(--shadow-sm); }
    .table tbody tr:last-child td { border-bottom: none; }
    .business-icon-wrap { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: rgba(30,45,64,0.08); }
    .business-icon-wrap i { font-size: 17px; color: var(--navy-light); }
    .badge { font-size: 11px; font-weight: 600; letter-spacing: 0.03em; padding: 5px 12px; border-radius: 12px; }
    .badge.bg-success { background: rgba(74,124,89,0.15) !important; color: #3a7d4f; }
    .badge.bg-secondary { background: rgba(92,107,124,0.15) !important; color: #5c6b7c; }
    .badge.bg-danger { background: rgba(162,73,58,0.15) !important; color: #a2493a; }
    .btn-action { padding: 6px 10px; font-size: 13px; border-radius: var(--radius-sm); transition: all 0.18s ease; }
    .btn-action:hover { transform: translateY(-1px); box-shadow: var(--shadow-sm); }
    .badge-active { background: rgba(74,124,89,0.12); color: #3a7d4f; border: 1px solid rgba(74,124,89,0.25); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-inactive { background: rgba(162,73,58,0.1); color: #a2493a; border: 1px solid rgba(162,73,58,0.2); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .validation-summary-valid { display: none !important; }
    .pagination { gap: 4px; }
    .pagination .page-link { border: 1px solid var(--border); color: var(--text-dark); padding: 6px 12px; font-size: 13px; border-radius: var(--radius-sm); transition: all 0.18s ease; }
    .pagination .page-link:hover { background: var(--gold-pale); border-color: var(--gold); color: var(--navy); }
    .pagination .page-item.active .page-link { background: var(--gold); border-color: var(--gold); color: var(--navy); font-weight: 600; }
    .pagination .page-item.disabled .page-link { background: var(--cream); border-color: var(--border); color: var(--text-light); pointer-events: none; }
    .modal-content { border: none; border-radius: var(--radius); box-shadow: var(--shadow-lg); }
    .modal-header { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%); border-bottom: none; border-radius: var(--radius) var(--radius) 0 0; padding: 20px 24px; }
    .modal-header .modal-title { font-size: 18px; font-weight: 700; color: var(--cream); display: flex; align-items: center; gap: 10px; }
    .modal-header .modal-title i { color: var(--gold-light); }
    .modal-header .btn-close { filter: brightness(0) invert(1); opacity: 0.7; }
    .modal-header .btn-close:hover { opacity: 1; }
    .modal-body { padding: 28px 24px; background: var(--ivory); }
    .modal-footer { background: var(--cream-dark); border-top: 1px solid var(--border); border-radius: 0 0 var(--radius) var(--radius); padding: 16px 24px; }
    .detail-row { display: flex; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid var(--border); gap: 16px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-light); width: 130px; flex-shrink: 0; }
    .detail-value { font-size: 14px; color: var(--text-dark); flex: 1; }
    .toast-container { position: fixed; top: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
    .toast-msg { padding: 12px 20px; border-radius: var(--radius-sm); font-size: 13.5px; font-weight: 500; box-shadow: var(--shadow-md); min-width: 260px; animation: fadeUp 0.3s ease both; }
    .toast-msg.success { background: #fff; border-left: 4px solid #3a7d4f; color: #3a7d4f; }
    .toast-msg.error { background: #fff; border-left: 4px solid #a2493a; color: #a2493a; }
    .empty-state { text-align: center; padding: 60px 20px; color: var(--text-light); }
    .empty-state i { font-size: 48px; margin-bottom: 12px; display: block; }
    .text-danger { color: #a2493a !important; }
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.45s ease 0.08s both; }
    .anim-2 { animation: fadeUp 0.45s ease 0.15s both; }
    @@media (max-width: 576px) { .page-header { padding: 24px 20px; } .page-header h1 { font-size: 1.5rem; } .page-header-actions { width: 100%; } }
</style>
}

<div class="toast-container" id="toastContainer"></div>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Management</a></li>
        <li class="breadcrumb-item active" aria-current="page">Business Management</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-content">
        <h1><i class="bi bi-building"></i>Business Management</h1>
        <p class="lead">Register and manage businesses operating in the market.</p>
    </div>
    <div class="page-header-actions">
        <button type="button" class="btn-gold" data-bs-toggle="modal" data-bs-target="#addBusinessModal">
            <i class="bi bi-plus-circle"></i>Add New Business
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search/Filter -->
<div class="card anim-1">
    <div class="card-body">
        <form method="get" asp-action="Index" class="row g-3">
            <div class="col-md-5">
                <label for="searchBusiness" class="form-label">Search Businesses</label>
                <div class="search-box">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="form-control" id="searchBusiness"
                           name="search" value="@Model.Search" placeholder="Search by name or tax code...">
                </div>
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn-classic navy"><i class="bi bi-funnel"></i>Search</button>
                <a asp-action="Index" class="btn-classic navy"><i class="bi bi-x-circle"></i>Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Business Table -->
<div class="card anim-2">
    <div class="card-header">
        <span>Showing <strong>@Model.TotalCount</strong> business@(Model.TotalCount != 1 ? "es" : "")
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <span class="text-muted"> for "<em>@Model.Search</em>"</span>
            }
        </span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" aria-label="Business list">
                <thead>
                    <tr>
                        <th scope="col">Business Name</th>
                        <th scope="col">Tax Code</th>
                        <th scope="col">Contact Email</th>
                        <th scope="col">Contact Phone</th>
                        <th scope="col">Status</th>
                        <th scope="col">Registered</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="bi bi-building-slash"></i>
                                    <div>No businesses found.</div>
                                    @if (!string.IsNullOrWhiteSpace(Model.Search))
                                    {
                                        <div class="mt-1">Try a different search term.</div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var b in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="business-icon-wrap"><i class="bi bi-building"></i></div>
                                        <strong>@b.Name</strong>
                                    </div>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(b.TaxCode) ? "-" : b.TaxCode)</td>
                                <td>@(string.IsNullOrWhiteSpace(b.ContactEmail) ? "-" : b.ContactEmail)</td>
                                <td>@(string.IsNullOrWhiteSpace(b.ContactPhone) ? "-" : b.ContactPhone)</td>
                                <td>
                                    @if (b.IsActive)
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </td>
                                <td>@b.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end" style="white-space:nowrap;">
                                    <button type="button" class="btn btn-sm btn-outline-primary btn-action"
                                            data-bs-toggle="tooltip" title="Edit"
                                            data-id="@b.Id"
                                            data-name="@b.Name"
                                            data-taxcode="@b.TaxCode"
                                            data-email="@b.ContactEmail"
                                            data-phone="@b.ContactPhone"
                                            data-active="@b.IsActive.ToString().ToLower()"
                                            onclick="openEditModal(this)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-info btn-action"
                                            data-bs-toggle="tooltip" title="View Details"
                                            data-id="@b.Id"
                                            data-name="@b.Name"
                                            data-taxcode="@b.TaxCode"
                                            data-email="@b.ContactEmail"
                                            data-phone="@b.ContactPhone"
                                            data-active="@b.IsActive.ToString().ToLower()"
                                            data-created="@b.CreatedAt.ToString("MMM dd, yyyy")"
                                            onclick="openDetailModal(this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <form asp-action="Deactivate" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <input type="hidden" name="page" value="@Model.Page" />
                                        <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                        <input type="hidden" name="search" value="@Model.Search" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-action"
                                                data-bs-toggle="tooltip" title="Deactivate"
                                                onclick="return confirm('Deactivate this business?')">
                                            <i class="bi bi-slash-circle"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalCount > 0)
    {
        <div class="card-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="text-muted" style="font-size:13px;">
                Showing @startIndex–@endIndex of @Model.TotalCount businesses
            </span>
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Business pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    }
</div>

<!-- Add Business Modal -->
<div class="modal fade" id="addBusinessModal" tabindex="-1" aria-labelledby="addBusinessModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addBusinessModalLabel">
                    <i class="bi bi-building-add"></i>Register New Business
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <input type="hidden" name="search" value="@Model.Search" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Create.Name" class="form-label">Business Name <span class="text-danger">*</span></label>
                            <input asp-for="Create.Name" class="form-control" placeholder="Enter business name">
                            <span asp-validation-for="Create.Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Create.TaxCode" class="form-label">Tax Code</label>
                            <input asp-for="Create.TaxCode" class="form-control" placeholder="e.g. 0123456789">
                            <span asp-validation-for="Create.TaxCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Create.ContactEmail" class="form-label">Contact Email</label>
                            <input asp-for="Create.ContactEmail" class="form-control" placeholder="contact@business.com">
                            <span asp-validation-for="Create.ContactEmail" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Create.ContactPhone" class="form-label">Contact Phone</label>
                            <input asp-for="Create.ContactPhone" class="form-control" placeholder="+84 123 456 789">
                            <span asp-validation-for="Create.ContactPhone" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="Create.IsActive" class="form-check-input" role="switch" />
                                <label asp-for="Create.IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-gold">
                        <i class="bi bi-check-circle"></i>Register Business
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Business Modal -->
<div class="modal fade" id="editBusinessModal" tabindex="-1" aria-labelledby="editBusinessModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editBusinessModalLabel">
                    <i class="bi bi-pencil-square"></i>Edit Business
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <input type="hidden" name="search" value="@Model.Search" />
                <div class="modal-body">
                    <input asp-for="Edit.Id" type="hidden" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Edit.Name" class="form-label">Business Name <span class="text-danger">*</span></label>
                            <input asp-for="Edit.Name" id="editBusinessName" class="form-control">
                            <span asp-validation-for="Edit.Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Edit.TaxCode" class="form-label">Tax Code</label>
                            <input asp-for="Edit.TaxCode" id="editTaxCode" class="form-control">
                            <span asp-validation-for="Edit.TaxCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Edit.ContactEmail" class="form-label">Contact Email</label>
                            <input asp-for="Edit.ContactEmail" id="editContactEmail" class="form-control">
                            <span asp-validation-for="Edit.ContactEmail" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Edit.ContactPhone" class="form-label">Contact Phone</label>
                            <input asp-for="Edit.ContactPhone" id="editContactPhone" class="form-control">
                            <span asp-validation-for="Edit.ContactPhone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Edit.IsActive" class="form-label">Status</label>
                            <select asp-for="Edit.IsActive" class="form-select" id="editBusinessStatus">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-gold">
                        <i class="bi bi-check-circle"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailBusinessModal" tabindex="-1" aria-labelledby="detailBusinessModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailBusinessModalLabel">
                    <i class="bi bi-building"></i>Business Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="detail-row"><div class="detail-label">Name</div><div class="detail-value" id="detailName">-</div></div>
                <div class="detail-row"><div class="detail-label">Tax Code</div><div class="detail-value" id="detailTaxCode">-</div></div>
                <div class="detail-row"><div class="detail-label">Contact Email</div><div class="detail-value" id="detailEmail">-</div></div>
                <div class="detail-row"><div class="detail-label">Contact Phone</div><div class="detail-value" id="detailPhone">-</div></div>
                <div class="detail-row"><div class="detail-label">Status</div><div class="detail-value" id="detailStatus">-</div></div>
                <div class="detail-row"><div class="detail-label">Registered</div><div class="detail-value" id="detailCreatedAt">-</div></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
                new bootstrap.Tooltip(el);
            });

            @if (Model.ShowCreateModal)
            {
                <text>new bootstrap.Modal(document.getElementById('addBusinessModal')).show();</text>
            }
            @if (Model.ShowEditModal)
            {
                <text>new bootstrap.Modal(document.getElementById('editBusinessModal')).show();</text>
            }
        });

        function openEditModal(btn) {
            const $btn = $(btn);
            $('#editBusinessName').val($btn.data('name'));
            $('#editTaxCode').val($btn.data('taxcode'));
            $('#editContactEmail').val($btn.data('email'));
            $('#editContactPhone').val($btn.data('phone'));
            $('#editBusinessStatus').val($btn.data('active'));
            $('input[name="Edit.Id"]').val($btn.data('id'));
            new bootstrap.Modal(document.getElementById('editBusinessModal')).show();
        }

        function openDetailModal(btn) {
            const $btn = $(btn);
            const isActive = $btn.data('active') === 'true' || $btn.data('active') === true;
            $('#detailName').text($btn.data('name'));
            $('#detailTaxCode').text($btn.data('taxcode') || '-');
            $('#detailEmail').text($btn.data('email') || '-');
            $('#detailPhone').text($btn.data('phone') || '-');
            $('#detailCreatedAt').text($btn.data('created') || '-');
            $('#detailStatus').html(`<span class="badge ${isActive ? 'bg-success' : 'bg-secondary'}">${isActive ? 'Active' : 'Inactive'}</span>`);
            new bootstrap.Modal(document.getElementById('detailBusinessModal')).show();
        }
    </script>
}
