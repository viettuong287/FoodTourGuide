@model Web.Models.StallNarrationContentManagementViewModel
@{
    ViewData["Title"] = "Stall Narration Content";
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
    var stallLookup = Model.Stalls.ToDictionary(s => s.Id, s => s.Name);
    var languageLookup = Model.Languages.ToDictionary(l => l.Id, l => l.Name);
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed;
        --cream-dark: #ede8df;
        --ivory: #faf8f4;
        --navy: #1e2d40;
        --navy-mid: #2c3e55;
        --gold: #b8964e;
        --gold-light: #d4ae6a;
        --gold-pale: #f0e4c8;
        --text-dark: #1e2d40;
        --text-mid: #4a5568;
        --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --radius: 10px;
        --radius-sm: 6px;
    }

    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius); padding: 32px 40px; margin-bottom: 28px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 20px; box-shadow: var(--shadow-md);
        position: relative; overflow: hidden;
    }
    .page-header::before {
        content: ''; position: absolute; top: -20px; right: -20px;
        width: 160px; height: 160px; border-radius: 50%;
        background: rgba(184,150,78,0.08); pointer-events: none;
    }
    .page-header-content { position: relative; z-index: 1; }
    .page-header-title {
        font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700;
        color: var(--cream); margin: 0 0 8px;
        display: flex; align-items: center; gap: 12px;
    }
    .page-header-title i { color: var(--gold-light); }
    .page-header-lead { font-size: 14px; color: rgba(247,243,237,0.7); margin: 0; }
    .page-header-actions { display: flex; gap: 10px; flex-wrap: wrap; position: relative; z-index: 1; }

    .btn-gold {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        color: var(--navy); border: none; font-weight: 600; font-size: 13.5px; padding: 10px 24px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        box-shadow: 0 2px 10px rgba(184,150,78,0.3);
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none; cursor: pointer;
    }
    .btn-gold:hover { color: var(--navy); box-shadow: 0 4px 16px rgba(184,150,78,0.4); transform: translateY(-1px); }
    .btn-ghost-cream {
        background: rgba(247,243,237,0.1); color: var(--cream);
        border: 1px solid rgba(247,243,237,0.25); font-weight: 500; font-size: 13.5px; padding: 10px 20px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
    }
    .btn-ghost-cream:hover { background: rgba(247,243,237,0.18); color: var(--cream); border-color: rgba(247,243,237,0.45); }

    .alert-success-custom { background: rgba(74,124,89,0.08); border: 1px solid rgba(74,124,89,0.2); border-radius: var(--radius-sm); color: #3a7d4f; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .alert-error-custom { background: rgba(162,73,58,0.08); border: 1px solid rgba(162,73,58,0.2); border-radius: var(--radius-sm); color: #a2493a; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }

    .card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 24px; }
    .card-body { padding: 20px 24px; }
    .card-footer { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 14px 20px; }
    .form-control, .form-select { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 9px 13px; font-size: 14px; color: var(--text-dark); background: #fff; transition: all 0.2s ease; outline: none; }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.12); }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 5px; }
    .btn-classic { display: inline-flex; align-items: center; gap: 5px; font-size: 13px; font-weight: 600; padding: 9px 18px; border-radius: var(--radius-sm); border: 1.5px solid; cursor: pointer; transition: all 0.18s ease; background: transparent; text-decoration: none; }
    .btn-classic-navy { border-color: var(--navy); color: var(--navy); }
    .btn-classic-navy:hover { background: var(--navy); color: var(--cream); }
    .btn-classic-outline { border-color: var(--border); color: var(--text-mid); }
    .btn-classic-outline:hover { border-color: var(--gold); color: var(--gold); }

    .table { margin: 0; font-size: 14px; }
    .table thead { background: var(--cream-dark); }
    .table thead th { font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); border-bottom: 2px solid var(--border); padding: 14px 16px; white-space: nowrap; }
    .table tbody td { padding: 14px 16px; vertical-align: middle; border-bottom: 1px solid var(--border); color: var(--text-dark); }
    .table tbody tr { background: #fff; transition: background 0.15s; }
    .table tbody tr:hover { background: var(--cream); }
    .table tbody tr:last-child td { border-bottom: none; }
    .badge-active { background: rgba(74,124,89,0.12); color: #3a7d4f; border: 1px solid rgba(74,124,89,0.25); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-inactive { background: rgba(162,73,58,0.1); color: #a2493a; border: 1px solid rgba(162,73,58,0.2); padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .btn-action { width: 30px; height: 30px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: var(--radius-sm); font-size: 14px; border: 1.5px solid; cursor: pointer; transition: all 0.15s ease; background: transparent; text-decoration: none; }
    .btn-action-view { border-color: #2b6cb0; color: #2b6cb0; }
    .btn-action-view:hover { background: #2b6cb0; color: #fff; }
    .btn-action-toggle-on { border-color: #b7791f; color: #b7791f; }
    .btn-action-toggle-on:hover { background: #b7791f; color: #fff; }
    .btn-action-toggle-off { border-color: #3a7d4f; color: #3a7d4f; }
    .btn-action-toggle-off:hover { background: #3a7d4f; color: #fff; }

    .pagination .page-link { border: 1px solid var(--border); color: var(--text-dark); padding: 6px 12px; font-size: 13px; border-radius: var(--radius-sm); transition: all 0.18s ease; }
    .pagination .page-link:hover { background: var(--gold-pale); border-color: var(--gold); color: var(--navy); }
    .pagination .page-item.active .page-link { background: var(--gold); border-color: var(--gold); color: var(--navy); font-weight: 600; }
    .pagination .page-item.disabled .page-link { background: var(--cream); border-color: var(--border); color: var(--text-light); }
    .empty-state { text-align: center; padding: 48px 24px; }
    .empty-state i { font-size: 48px; color: var(--border); margin-bottom: 16px; display: block; }
    .empty-state p { color: var(--text-light); font-size: 14px; margin: 0; }

    /* Modal */
    .modal-header-navy { background: linear-gradient(135deg, var(--navy), var(--navy-mid)); }
    .modal-header-navy .modal-title { color: var(--cream); font-family: 'Playfair Display', serif; font-size: 1.1rem; display: flex; align-items: center; gap: 8px; }
    .modal-header-navy .modal-title i { color: var(--gold-light); }
    .modal-header-navy .btn-close { filter: brightness(10); }
    .modal-content { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .modal-body { padding: 24px; background: var(--ivory); }
    .modal-footer { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 14px 20px; }
    .btn-modal-primary { background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: var(--navy); border: none; font-weight: 600; font-size: 13.5px; padding: 9px 20px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s; }
    .btn-modal-primary:hover { box-shadow: 0 4px 12px rgba(184,150,78,0.4); transform: translateY(-1px); }
    .btn-modal-secondary { background: transparent; color: var(--text-mid); border: 1.5px solid var(--border); font-weight: 500; font-size: 13.5px; padding: 9px 20px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s; }
    .btn-modal-secondary:hover { border-color: var(--navy); color: var(--navy); }
    .btn-modal-activate { background: rgba(74,124,89,0.1); color: #3a7d4f; border: 1.5px solid rgba(74,124,89,0.3); font-weight: 600; font-size: 13.5px; padding: 9px 20px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s; }
    .btn-modal-activate:hover { background: #3a7d4f; color: #fff; border-color: #3a7d4f; }
    .btn-modal-deactivate { background: rgba(183,121,31,0.1); color: #b7791f; border: 1.5px solid rgba(183,121,31,0.3); font-weight: 600; font-size: 13.5px; padding: 9px 20px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s; }
    .btn-modal-deactivate:hover { background: #b7791f; color: #fff; border-color: #b7791f; }

    .input-group-text { background: var(--cream-dark); border: 1px solid var(--border); color: var(--text-mid); }
    .form-check-input:checked { background-color: var(--gold); border-color: var(--gold); }

    @@keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.45s ease 0.08s both; }
    .anim-2 { animation: fadeUp 0.45s ease 0.15s both; }
    @@media (max-width: 576px) { .page-header { padding: 24px 20px; } .page-header-title { font-size: 1.5rem; } .page-header-actions { width: 100%; } }
</style>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a href="#">Management</a></li>
        <li class="breadcrumb-item active" aria-current="page">Stall Narration Content</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-header-title">
            <i class="bi bi-mic" aria-hidden="true"></i>Stall Narration Content
        </h1>
        <p class="page-header-lead">Quản lý nội dung narration theo stall và ngôn ngữ.</p>
    </div>
    <div class="page-header-actions">
        <button type="button" class="btn-gold" data-bs-toggle="modal" data-bs-target="#createNarrationContentModal">
            <i class="bi bi-plus-circle" aria-hidden="true"></i>Thêm nội dung thuyết minh
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-error-custom">
        <i class="bi bi-exclamation-circle-fill"></i>@Model.ErrorMessage
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success-custom">
        <i class="bi bi-check-circle-fill"></i>@TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error-custom">
        <i class="bi bi-exclamation-circle-fill"></i>@TempData["ErrorMessage"]
    </div>
}

<!-- Filters -->
<div class="card anim-1">
    <div class="card-body">
        <form method="get" asp-action="StallNarrationContents" class="row g-3">
            <div class="col-md-4">
                <label for="narrationSearch" class="form-label">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" id="narrationSearch" name="search" value="@Model.Search" placeholder="Tìm theo tiêu đề hoặc mô tả..." />
                </div>
            </div>
            <div class="col-md-2">
                <label for="stallFilter" class="form-label">Stall</label>
                <select class="form-select" id="stallFilter" name="stallId">
                    <option value="">Tất cả stall</option>
                    @foreach (var stall in Model.Stalls)
                    {
                        <option value="@stall.Id" selected="@(Model.StallId == stall.Id)">@stall.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label for="languageFilter" class="form-label">Ngôn ngữ</label>
                <select class="form-select" id="languageFilter" name="languageId">
                    <option value="">Tất cả ngôn ngữ</option>
                    @foreach (var language in Model.Languages)
                    {
                        <option value="@language.Id" selected="@(Model.LanguageId == language.Id)">@language.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label for="statusFilter" class="form-label">Trạng thái</label>
                <select class="form-select" id="statusFilter" name="isActive">
                    <option value="" selected="@(Model.IsActive == null)">Tất cả</option>
                    <option value="true" selected="@(Model.IsActive == true)">Active</option>
                    <option value="false" selected="@(Model.IsActive == false)">Inactive</option>
                </select>
            </div>
            <div class="col-md-1">
                <label for="pageSize" class="form-label">Hiển thị</label>
                <select class="form-select" id="pageSize" name="pageSize">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end gap-2">
                <button type="submit" class="btn-classic btn-classic-navy">
                    <i class="bi bi-funnel"></i>
                </button>
            </div>
            <div class="col-12">
                <a asp-action="StallNarrationContents" class="btn-classic btn-classic-outline" style="font-size:12px;padding:7px 14px;">
                    <i class="bi bi-x-circle"></i>Xóa bộ lọc
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card anim-2">
    <div class="card-body p-0">
        @if (Model.Items.Count == 0)
        {
            <div class="empty-state">
                <i class="bi bi-mic" aria-hidden="true"></i>
                <p>Chưa có narration content.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table" aria-label="Narration content list">
                    <thead>
                        <tr>
                            <th scope="col">Tiêu đề</th>
                            <th scope="col">Gian hàng</th>
                            <th scope="col">Ngôn ngữ gốc</th>
                            <th scope="col">Trạng thái</th>
                            <th scope="col">Cập nhật</th>
                            <th scope="col" class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            var stallName = stallLookup.TryGetValue(item.StallId, out var stallValue) ? stallValue : item.StallId.ToString();
                            var languageName = languageLookup.TryGetValue(item.LanguageId, out var langValue) ? langValue : item.LanguageId.ToString();
                            <tr>
                                <td>
                                    <span style="font-weight:600">@item.Title</span>
                                    <small class="d-block" style="font-size:11px;color:var(--text-light)">ID: @item.Id</small>
                                </td>
                                <td>@stallName</td>
                                <td>@languageName</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Inactive</span>
                                    }
                                </td>
                                <td style="font-size:12.5px;color:var(--text-light)">@(item.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td class="text-end">
                                    <div style="display:inline-flex;gap:6px;">
                                        <a class="btn-action btn-action-view" title="Xem / Chỉnh sửa"
                                           asp-controller="Narration" asp-action="Show" asp-route-id="@item.Id">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button type="button"
                                                class="btn-action @(item.IsActive ? "btn-action-toggle-on" : "btn-action-toggle-off")"
                                                title="@(item.IsActive ? "Vô hiệu hóa" : "Kích hoạt")"
                                                data-bs-toggle="modal"
                                                data-bs-target="#toggleStatusModal"
                                                data-id="@item.Id"
                                                data-title="@item.Title"
                                                data-is-active="@item.IsActive.ToString().ToLowerInvariant()">
                                            <i class="bi @(item.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span style="font-size:13px;color:var(--text-light)">
            Hiển thị @startIndex–@endIndex trong tổng @Model.TotalCount bản ghi
        </span>
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Narration pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="StallNarrationContents"
                           asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search" asp-route-stallId="@Model.StallId"
                           asp-route-languageId="@Model.LanguageId" asp-route-isActive="@Model.IsActive">‹</a>
                    </li>
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="StallNarrationContents"
                               asp-route-page="@i" asp-route-pageSize="@Model.PageSize"
                               asp-route-search="@Model.Search" asp-route-stallId="@Model.StallId"
                               asp-route-languageId="@Model.LanguageId" asp-route-isActive="@Model.IsActive">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="StallNarrationContents"
                           asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search" asp-route-stallId="@Model.StallId"
                           asp-route-languageId="@Model.LanguageId" asp-route-isActive="@Model.IsActive">›</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

<!-- Toggle Status Modal -->
<div class="modal fade" id="toggleStatusModal" tabindex="-1" aria-labelledby="toggleStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Narration" asp-action="ToggleStatus" method="post" id="toggleStatusForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="toggleStatusId" />
                <input type="hidden" name="isActive" id="toggleStatusIsActive" />
                <div class="modal-header modal-header-navy">
                    <h5 class="modal-title" id="toggleStatusModalLabel">
                        <i class="bi bi-toggle-on"></i>Xác nhận đổi trạng thái
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="toggleStatusMessage" style="color:var(--text-dark);font-size:14px;margin:0;line-height:1.6;"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-modal-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x"></i>Hủy
                    </button>
                    <button type="submit" class="btn-modal-activate" id="toggleStatusConfirmBtn">Xác nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Narration Content Modal -->
<div class="modal fade" id="createNarrationContentModal" tabindex="-1" aria-labelledby="createNarrationContentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-controller="Narration" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header modal-header-navy">
                    <h5 class="modal-title" id="createNarrationContentModalLabel">
                        <i class="bi bi-plus-circle"></i>Thêm nội dung Narration
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="createStallId" class="form-label">Stall <span style="color:#a2493a">*</span></label>
                            <select class="form-select" id="createStallId" name="StallId" required>
                                <option value="">-- Chọn stall --</option>
                                @foreach (var stall in Model.Stalls)
                                {
                                    <option value="@stall.Id">@stall.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="createLanguageId" class="form-label">Ngôn ngữ gốc <span style="color:#a2493a">*</span></label>
                            <select class="form-select" id="createLanguageId" name="LanguageId" required>
                                <option value="">-- Chọn ngôn ngữ gốc --</option>
                                @foreach (var language in Model.Languages)
                                {
                                    <option value="@language.Id">@language.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="createTitle" class="form-label">Tiêu đề <span style="color:#a2493a">*</span></label>
                            <input type="text" class="form-control" id="createTitle" name="Title" maxlength="128" required placeholder="Nhập tiêu đề..." />
                        </div>
                        <div class="col-12">
                            <label for="createDescription" class="form-label">Mô tả</label>
                            <input type="text" class="form-control" id="createDescription" name="Description" maxlength="256" placeholder="Nhập mô tả (tùy chọn)..." />
                        </div>
                        <div class="col-12">
                            <label for="createScriptText" class="form-label">Nội dung kịch bản <span style="color:#a2493a">*</span></label>
                            <textarea class="form-control" id="createScriptText" name="ScriptText" rows="5" required placeholder="Nhập nội dung kịch bản..."></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="createIsActive" name="IsActive" value="true" checked />
                                <label class="form-check-label" for="createIsActive" style="font-size:14px;color:var(--text-dark)">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-modal-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x"></i>Hủy
                    </button>
                    <button type="submit" class="btn-modal-primary">
                        <i class="bi bi-plus-lg"></i>Tạo nội dung & thuyết minh tự động
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('toggleStatusModal').addEventListener('show.bs.modal', function (event) {
        var btn = event.relatedTarget;
        var id = btn.getAttribute('data-id');
        var title = btn.getAttribute('data-title');
        var isActive = btn.getAttribute('data-is-active') === 'true';
        var newState = !isActive;

        document.getElementById('toggleStatusId').value = id;
        document.getElementById('toggleStatusIsActive').value = newState;

        var message = document.getElementById('toggleStatusMessage');
        var confirmBtn = document.getElementById('toggleStatusConfirmBtn');

        if (newState) {
            message.innerHTML = 'Bạn có chắc muốn <strong>kích hoạt</strong> nội dung <strong>"' + title + '"</strong>?<br><small style="color:var(--text-light)">Các nội dung khác của cùng stall sẽ bị deactivate.</small>';
            confirmBtn.className = 'btn-modal-activate';
            confirmBtn.innerHTML = '<i class="bi bi-check-lg"></i>Kích hoạt';
        } else {
            message.innerHTML = 'Bạn có chắc muốn <strong>vô hiệu hóa</strong> nội dung <strong>"' + title + '"</strong>?';
            confirmBtn.className = 'btn-modal-deactivate';
            confirmBtn.innerHTML = '<i class="bi bi-slash-circle"></i>Vô hiệu hóa';
        }
    });
</script>
}
