
@model Web.Models.StallNarrationContentShowViewModel
@{
    ViewData["Title"] = "Stall Narration Content";
    var content = Model.Content;
}

@section Styles {
<style>
    :root {
        --cream: #f7f3ed;
        --cream-dark: #ede8df;
        --ivory: #faf8f4;
        --navy: #1e2d40;
        --navy-mid: #2c3e55;
        --gold: #b8964e;
        --gold-light: #d4ae6a;
        --gold-pale: #f0e4c8;
        --text-dark: #1e2d40;
        --text-mid: #4a5568;
        --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --radius: 10px;
        --radius-sm: 6px;
    }

    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius); padding: 32px 40px; margin-bottom: 28px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 20px; box-shadow: var(--shadow-md);
        position: relative; overflow: hidden;
    }
    .page-header::before {
        content: ''; position: absolute; top: -20px; right: -20px;
        width: 160px; height: 160px; border-radius: 50%;
        background: rgba(184,150,78,0.08); pointer-events: none;
    }
    .page-header-content { position: relative; z-index: 1; }
    .page-header-title {
        font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700;
        color: var(--cream); margin: 0 0 8px;
        display: flex; align-items: center; gap: 12px;
    }
    .page-header-title i { color: var(--gold-light); }
    .page-header-lead { font-size: 14px; color: rgba(247,243,237,0.7); margin: 0; }
    .page-header-actions { display: flex; gap: 10px; flex-wrap: wrap; position: relative; z-index: 1; }
    .btn-ghost-cream {
        background: rgba(247,243,237,0.1); color: var(--cream);
        border: 1px solid rgba(247,243,237,0.25); font-weight: 500; font-size: 13.5px; padding: 10px 20px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
    }
    .btn-ghost-cream:hover { background: rgba(247,243,237,0.18); color: var(--cream); border-color: rgba(247,243,237,0.45); }

    .alert-success-custom { background: rgba(74,124,89,0.08); border: 1px solid rgba(74,124,89,0.2); border-radius: var(--radius-sm); color: #3a7d4f; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .alert-error-custom { background: rgba(162,73,58,0.08); border: 1px solid rgba(162,73,58,0.2); border-radius: var(--radius-sm); color: #a2493a; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }

    .card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; margin-bottom: 24px; }
    .card-header-nav {
        background: linear-gradient(135deg, var(--navy), var(--navy-mid));
        padding: 16px 24px; display: flex; align-items: center; justify-content: space-between;
    }
    .card-header-nav-title {
        font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 600;
        color: var(--cream); display: flex; align-items: center; gap: 8px; margin: 0;
    }
    .card-header-nav-title i { color: var(--gold-light); }
    .card-body { padding: 24px; }
    .card-footer { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 14px 24px; display: flex; justify-content: flex-end; gap: 10px; }

    .form-control, .form-select { border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 9px 13px; font-size: 14px; color: var(--text-dark); background: #fff; transition: all 0.2s ease; outline: none; }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.12); }
    .form-control[readonly] { background: var(--cream); color: var(--text-mid); cursor: default; }
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 5px; }

    .btn-save {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        color: var(--navy); border: none; font-weight: 600; font-size: 13.5px; padding: 10px 24px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        box-shadow: 0 2px 10px rgba(184,150,78,0.3);
        display: inline-flex; align-items: center; gap: 8px; cursor: pointer;
    }
    .btn-save:hover { box-shadow: 0 4px 16px rgba(184,150,78,0.4); transform: translateY(-1px); }

    /* Audio table */
    .audio-section-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 16px 24px; border-bottom: 1px solid var(--border);
        background: var(--cream-dark);
    }
    .audio-section-title {
        font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 600;
        color: var(--text-dark); display: flex; align-items: center; gap: 8px; margin: 0;
    }
    .audio-section-title i { color: var(--gold); }
    .btn-toggle-all {
        background: transparent; color: var(--text-mid); border: 1.5px solid var(--border);
        font-size: 13px; font-weight: 500; padding: 7px 14px;
        border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 6px;
        cursor: pointer; transition: all 0.18s;
    }
    .btn-toggle-all:hover { border-color: var(--navy); color: var(--navy); }

    .grouped-table { width: 100%; border-collapse: collapse; background: #fff; font-size: 14px; }
    .grouped-table thead { background: var(--cream-dark); }
    .grouped-table thead th { padding: 13px 16px; text-align: left; font-weight: 600; font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); border-bottom: 2px solid var(--border); white-space: nowrap; }
    .grouped-table tbody tr { border-bottom: 1px solid var(--border); transition: background 0.15s; }
    .grouped-table tbody tr:hover { background: var(--cream); }
    .grouped-table td { padding: 13px 16px; color: var(--text-dark); vertical-align: middle; }

    .language-group-row { background: var(--gold-pale) !important; }
    .language-group-row td { padding: 10px 16px; }
    .language-group-row:hover { background: var(--gold-pale) !important; }

    .toggle-group-btn {
        background: none; border: none; color: var(--navy);
        cursor: pointer; padding: 0 6px; font-size: 13px; font-weight: 600;
    }
    .toggle-group-btn.collapsed::before { content: '▶ '; }
    .toggle-group-btn:not(.collapsed)::before { content: '▼ '; }

    .voice-row { display: none; }
    .voice-row.show { display: table-row; }

    .form-check-input:checked { background-color: var(--gold); border-color: var(--gold); }

    /* TTS Status */
    .tts-status-card { border-radius: var(--radius); margin-bottom: 24px; overflow: hidden; border: 1px solid; }
    .tts-status-pending { background: rgba(59,130,246,0.07); border-color: rgba(59,130,246,0.25); }
    .tts-status-processing { background: rgba(184,150,78,0.07); border-color: rgba(184,150,78,0.3); }
    .tts-status-completed { background: rgba(74,124,89,0.07); border-color: rgba(74,124,89,0.25); }
    .tts-status-failed { background: rgba(162,73,58,0.07); border-color: rgba(162,73,58,0.3); }
    .tts-status-none { background: var(--cream); border-color: var(--border); }
    .tts-status-body { padding: 16px 20px; display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .tts-status-icon { font-size: 20px; flex-shrink: 0; }
    .tts-status-text { flex: 1; min-width: 0; }
    .tts-status-label { font-weight: 600; font-size: 13.5px; margin-bottom: 2px; }
    .tts-status-sub { font-size: 12.5px; color: var(--text-light); margin: 0; }
    .tts-error-detail { font-size: 12.5px; color: #a2493a; margin-top: 4px; word-break: break-word; }
    .btn-retry-tts { background: rgba(162,73,58,0.1); color: #a2493a; border: 1.5px solid rgba(162,73,58,0.3); font-weight: 600; font-size: 13px; padding: 8px 16px; border-radius: var(--radius-sm); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
    .btn-retry-tts:hover { background: #a2493a; color: #fff; border-color: #a2493a; }
    @@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .spin { display: inline-block; animation: spin 1s linear infinite; }

    @@keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.45s ease 0.08s both; }
    .anim-2 { animation: fadeUp 0.45s ease 0.15s both; }
    @@media (max-width: 576px) { .page-header { padding: 24px 20px; } .page-header-title { font-size: 1.5rem; } .page-header-actions { width: 100%; } }
    @@media (max-width: 768px) { .grouped-table th, .grouped-table td { padding: 8px; font-size: 13px; } }
</style>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Narration" asp-action="StallNarrationContents">Narration</a></li>
        <li class="breadcrumb-item active" aria-current="page">Stall Narration Content</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-header-title">
            <i class="bi bi-file-earmark-music" aria-hidden="true"></i>Stall Narration Content
        </h1>
        <p class="page-header-lead">Xem và chỉnh sửa nội dung narration của stall.</p>
    </div>
    <div class="page-header-actions">
        <a class="btn-ghost-cream" asp-controller="Narration" asp-action="StallNarrationContents">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>Quay lại
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert-success-custom">
        <i class="bi bi-check-circle-fill"></i>@successMsg
    </div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert-error-custom">
        <i class="bi bi-exclamation-circle-fill"></i>@Model.ErrorMessage
    </div>
}

<!-- Edit Form Card -->
<div class="card anim-1">
    <div class="card-header-nav">
        <h2 class="card-header-nav-title">
            <i class="bi bi-pencil-square"></i>Chỉnh sửa nội dung
        </h2>
    </div>
    <form id="textContentForm" asp-action="Update" asp-route-id="@content?.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label" for="stallName">Stall</label>
                    <input class="form-control" id="stallName" type="text" value="@Model.StallName" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label" for="languageName">Ngôn ngữ</label>
                    <input class="form-control" id="languageName" type="text" value="@Model.LanguageName" readonly />
                </div>
                <div class="col-12">
                    <label class="form-label" for="contentTitle">Tiêu đề <span style="color:#a2493a">*</span></label>
                    <input class="form-control" id="contentTitle" name="Title" type="text" value="@content?.Title" required />
                </div>
                <div class="col-12">
                    <label class="form-label" for="contentDescription">Mô tả</label>
                    <textarea class="form-control" id="contentDescription" name="Description" rows="3">@content?.Description</textarea>
                </div>
                <div class="col-12">
                    <label class="form-label" for="scriptContent">Kịch bản <span style="color:#a2493a">*</span></label>
                    <textarea class="form-control" id="scriptContent" name="ScriptText" rows="8" required>@content?.ScriptText</textarea>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="contentStatus">Trạng thái</label>
                    <select class="form-select" id="contentStatus" name="IsActive" required>
                        <option value="true" selected="@(content?.IsActive == true)">Active</option>
                        <option value="false" selected="@(content?.IsActive == false)">Inactive</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn-save">
                <i class="bi bi-check-lg"></i>Cập nhật nội dung
            </button>
        </div>
    </form>
</div>

<!-- TTS Status -->
@{
    var ttsStatus = content?.TtsStatus ?? "None";
    var ttsError  = content?.TtsError;
    var contentId = content?.Id ?? Guid.Empty;
    string ttsCardClass, ttsIconHtml, ttsLabel, ttsSub;
    bool isPolling = ttsStatus == "Pending" || ttsStatus == "Processing";
    switch (ttsStatus)
    {
        case "Pending":
            ttsCardClass = "tts-status-pending";
            ttsIconHtml  = "<span class=\"spin\" style=\"color:#3b82f6\"><i class=\"bi bi-hourglass-split\"></i></span>";
            ttsLabel     = "Đang chờ tạo thuyết minh...";
            ttsSub       = "Hệ thống sẽ tự động tạo audio cho tất cả ngôn ngữ. Trang sẽ tự làm mới khi hoàn thành.";
            break;
        case "Processing":
            ttsCardClass = "tts-status-processing";
            ttsIconHtml  = "<span class=\"spin\" style=\"color:var(--gold)\"><i class=\"bi bi-gear\"></i></span>";
            ttsLabel     = "Đang tạo thuyết minh đa ngôn ngữ...";
            ttsSub       = "Azure TTS đang dịch và tạo audio. Trang sẽ tự làm mới khi hoàn thành.";
            break;
        case "Completed":
            bool completedHasAudio = Model.Audios.Count > 0;
            ttsCardClass = completedHasAudio ? "tts-status-completed" : "tts-status-failed";
            ttsIconHtml  = completedHasAudio
                ? "<i class=\"bi bi-check-circle-fill\" style=\"color:#3a7d4f\"></i>"
                : "<i class=\"bi bi-exclamation-circle-fill\" style=\"color:#a2493a\"></i>";
            ttsLabel     = completedHasAudio ? "Thuyết minh đa ngôn ngữ đã sẵn sàng" : "Hoàn thành nhưng không có audio nào được tạo";
            ttsSub       = completedHasAudio ? "Tất cả audio đã được tạo và lưu ở bên dưới." : "Có thể do lỗi cấu hình Azure. Vui lòng kiểm tra lại và tạo lại.";
            break;
        case "Failed":
            ttsCardClass = "tts-status-failed";
            ttsIconHtml  = "<i class=\"bi bi-exclamation-circle-fill\" style=\"color:#a2493a\"></i>";
            ttsLabel     = "Tạo thuyết minh thất bại";
            ttsSub       = "Vui lòng kiểm tra lỗi và thử lại.";
            break;
        default:
            ttsCardClass = "tts-status-none";
            ttsIconHtml  = "<i class=\"bi bi-info-circle\" style=\"color:var(--text-light)\"></i>";
            ttsLabel     = "Chưa có TTS";
            ttsSub       = "Gói hiện tại không hỗ trợ tự động tạo thuyết minh.";
            break;
    }
}
<div class="tts-status-card @ttsCardClass" id="ttsStatusCard" data-content-id="@contentId" data-tts-status="@ttsStatus">
    <div class="tts-status-body">
        <div class="tts-status-icon">@Html.Raw(ttsIconHtml)</div>
        <div class="tts-status-text">
            <div class="tts-status-label" id="ttsStatusLabel">@ttsLabel</div>
            <p class="tts-status-sub" id="ttsStatusSub">@ttsSub</p>
            @if (ttsStatus == "Failed" && !string.IsNullOrWhiteSpace(ttsError))
            {
                <p class="tts-error-detail" id="ttsErrorDetail"><i class="bi bi-bug"></i> @ttsError</p>
            }
        </div>
        @if (ttsStatus == "Failed" || (ttsStatus == "Completed" && Model.Audios.Count == 0))
        {
            <form asp-action="RetryTts" asp-route-id="@contentId" method="post" style="flex-shrink:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-retry-tts">
                    <i class="bi bi-arrow-repeat"></i>@(ttsStatus == "Failed" ? "Thử lại TTS" : "Tạo lại thuyết minh")
                </button>
            </form>
        }
    </div>
</div>

<!-- Narration Audio Table -->
<div class="card anim-2">
    <div class="audio-section-header">
        <h2 class="audio-section-title">
            <i class="bi bi-music-note-list"></i>Danh sách narration audio
        </h2>
        <button type="button" class="btn-toggle-all" id="toggleAllAudioGroups">
            <i class="bi bi-chevron-down"></i>Mở rộng tất cả
        </button>
    </div>
    <div class="table-responsive">
        <table class="grouped-table" aria-label="Narration audio list">
            <thead>
                <tr>
                    <th>Ngôn ngữ</th>
                    <th>TtsVoiceProfile</th>
                    <th>Duration (s)</th>
                    <th>Is TTS</th>
                    <th>Updated</th>
                    <th>Audio Url</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Audios.Count == 0)
                {
                    <tr>
                        <td colspan="6" style="text-align:center;padding:40px;color:var(--text-light);">
                            <i class="bi bi-music-note" style="font-size:32px;display:block;margin-bottom:12px;color:var(--border);"></i>
                            Chưa có narration audio.
                        </td>
                    </tr>
                }
                else
                {
                    var groupedAudios = Model.Audios
                        .GroupBy(a => a.TtsVoiceProfileLanguageName ?? "Không rõ")
                        .OrderBy(g => g.Key)
                        .ToList();
                    var groupIndex = 0;
                    foreach (var group in groupedAudios)
                    {
                        var groupId = $"audio-group-{groupIndex}";
                        <tr class="language-group-row" data-group-id="@groupId">
                            <td colspan="6">
                                <button type="button" class="toggle-group-btn collapsed" data-group-target="@groupId" aria-expanded="false"></button>
                                <strong style="color:var(--navy)">@group.Key</strong>
                                <span style="color:var(--text-mid);font-size:12px;margin-left:6px;">(@group.Count() giọng)</span>
                            </td>
                        </tr>
                        foreach (var audio in group)
                        {
                            <tr class="voice-row" data-group-id="@groupId">
                                <td>@group.Key</td>
                                <td>@(audio.TtsVoiceProfileDescription ?? "-")</td>
                                <td>@(audio.DurationSeconds?.ToString() ?? "-")</td>
                                <td>
                                    @if (audio.IsTts)
                                    {
                                        <span style="background:rgba(74,124,89,0.12);color:#3a7d4f;border:1px solid rgba(74,124,89,0.25);padding:2px 8px;border-radius:12px;font-size:11px;font-weight:600;">TTS</span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-light);font-size:13px;">No</span>
                                    }
                                </td>
                                <td style="font-size:12.5px;color:var(--text-light)">@(audio.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(audio.AudioUrl))
                                    {
                                        <a href="@audio.AudioUrl" target="_blank" style="color:var(--navy);font-size:13px;display:inline-flex;align-items:center;gap:4px;">
                                            <i class="bi bi-play-circle"></i>Open
                                        </a>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-light)">-</span>
                                    }
                                </td>
                            </tr>
                        }
                        groupIndex++;
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    // ── TTS status polling ────────────────────────────────────────────────────
    (function () {
        var card = document.getElementById('ttsStatusCard');
        if (!card) return;

        var status = card.getAttribute('data-tts-status');
        if (status !== 'Pending' && status !== 'Processing') return;

        var contentId = card.getAttribute('data-content-id');
        var pollInterval = 5000; // 5 seconds

        function pollTtsStatus() {
            fetch('/Narration/TtsStatus/' + contentId, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    var result = data && data.data ? data.data : null;
                    if (!result) return;

                    var newStatus = result.ttsStatus || 'None';
                    card.setAttribute('data-tts-status', newStatus);

                    if (newStatus === 'Completed' || newStatus === 'Failed') {
                        // Reload the page to show updated audio list and status
                        window.location.reload();
                    }
                    // Still pending/processing → continue polling
                })
                .catch(function () { /* swallow polling errors silently */ });
        }

        setInterval(pollTtsStatus, pollInterval);
    })();
</script>
<script>
    (function () {
        function toggleGroup(groupId, expand) {
            var rows = document.querySelectorAll('.voice-row[data-group-id="' + groupId + '"]');
            var button = document.querySelector('.toggle-group-btn[data-group-target="' + groupId + '"]');
            if (!button) return;
            if (expand) {
                rows.forEach(function (row) { row.classList.add('show'); });
                button.classList.remove('collapsed');
                button.setAttribute('aria-expanded', 'true');
            } else {
                rows.forEach(function (row) { row.classList.remove('show'); });
                button.classList.add('collapsed');
                button.setAttribute('aria-expanded', 'false');
            }
        }

        document.querySelectorAll('.toggle-group-btn[data-group-target]').forEach(function (button) {
            button.addEventListener('click', function () {
                var groupId = button.getAttribute('data-group-target');
                var isCollapsed = button.classList.contains('collapsed');
                toggleGroup(groupId, isCollapsed);
            });
        });

        var toggleAllButton = document.getElementById('toggleAllAudioGroups');
        if (toggleAllButton) {
            var allExpanded = false;
            toggleAllButton.addEventListener('click', function () {
                var groupButtons = document.querySelectorAll('.toggle-group-btn[data-group-target]');
                allExpanded = !allExpanded;
                groupButtons.forEach(function (button) {
                    var groupId = button.getAttribute('data-group-target');
                    toggleGroup(groupId, allExpanded);
                });
                toggleAllButton.innerHTML = allExpanded
                    ? '<i class="bi bi-chevron-up"></i>Thu gọn tất cả'
                    : '<i class="bi bi-chevron-down"></i>Mở rộng tất cả';
            });
        }
    })();
</script>
}
