@using System.Globalization
@{
    ViewData["Title"] = "Stall Location Map";
    var mode = ViewBag.Mode ?? "view"; // create, edit, view
    var stallId = ViewBag.StallId as Guid?;
    var locationId = ViewBag.LocationId as Guid?;
    var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "https://localhost:7188/";

    var latStr = ViewBag.Latitude != null ? ((decimal)ViewBag.Latitude).ToString("F6", CultureInfo.InvariantCulture) : "";
    var lngStr = ViewBag.Longitude != null ? ((decimal)ViewBag.Longitude).ToString("F6", CultureInfo.InvariantCulture) : "";
    var radiusStr = ViewBag.RadiusMeters != null ? ((decimal)ViewBag.RadiusMeters).ToString("G", CultureInfo.InvariantCulture) : "8";
    var modeLabel = mode == "create" ? "Add Location" : (mode == "edit" ? "Edit Location" : "View Location");
}

@section Styles {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<style>
    :root {
        --cream: #f7f3ed;
        --cream-dark: #ede8df;
        --ivory: #faf8f4;
        --navy: #1e2d40;
        --navy-mid: #2c3e55;
        --gold: #b8964e;
        --gold-light: #d4ae6a;
        --gold-pale: #f0e4c8;
        --text-dark: #1e2d40;
        --text-mid: #4a5568;
        --text-light: #718096;
        --border: #d9cfc2;
        --shadow-sm: 0 1px 4px rgba(30,45,64,0.07);
        --shadow-md: 0 4px 16px rgba(30,45,64,0.10);
        --shadow-lg: 0 8px 32px rgba(30,45,64,0.13);
        --radius: 10px;
        --radius-sm: 6px;
        --status-green: #4a7c59;
    }

    /* ── BREADCRUMB ── */
    .breadcrumb { background: transparent; padding: 0 0 12px; margin-bottom: 20px; font-size: 13px; }
    .breadcrumb-item a { color: var(--text-mid); text-decoration: none; transition: color 0.15s; }
    .breadcrumb-item a:hover { color: var(--gold); }
    .breadcrumb-item.active { color: var(--text-light); }
    .breadcrumb-item + .breadcrumb-item::before { color: var(--border); }

    /* ── PAGE HEADER ── */
    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: var(--radius); padding: 32px 40px; margin-bottom: 28px;
        display: flex; justify-content: space-between; align-items: center;
        flex-wrap: wrap; gap: 20px; box-shadow: var(--shadow-md);
        position: relative; overflow: hidden;
    }
    .page-header::before {
        content: ''; position: absolute; top: -20px; right: -20px;
        width: 160px; height: 160px; border-radius: 50%;
        background: rgba(184,150,78,0.08); pointer-events: none;
    }
    .page-header-content { position: relative; z-index: 1; }
    .page-header-title {
        font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700;
        color: var(--cream); margin: 0 0 8px; display: flex; align-items: center; gap: 12px;
    }
    .page-header-title i { color: var(--gold-light); }
    .page-header-lead { font-size: 14px; color: rgba(247,243,237,0.7); margin: 0; }
    .page-header-actions { display: flex; gap: 10px; flex-wrap: wrap; position: relative; z-index: 1; }
    .btn-ghost-cream {
        background: rgba(247,243,237,0.1); color: var(--cream);
        border: 1px solid rgba(247,243,237,0.25); font-weight: 500; font-size: 13.5px; padding: 10px 20px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
    }
    .btn-ghost-cream:hover { background: rgba(247,243,237,0.18); color: var(--cream); border-color: rgba(247,243,237,0.45); }

    /* ── ALERTS ── */
    .alert-success-custom { background: rgba(74,124,89,0.08); border: 1px solid rgba(74,124,89,0.2); border-radius: var(--radius-sm); color: #3a7d4f; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .alert-error-custom { background: rgba(162,73,58,0.08); border: 1px solid rgba(162,73,58,0.2); border-radius: var(--radius-sm); color: #a2493a; padding: 12px 16px; font-size: 13.5px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }

    /* ── CARD ── */
    .card { background: var(--ivory); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); overflow: hidden; }
    .card-header-nav {
        background: var(--cream-dark); border-bottom: 1px solid var(--border);
        padding: 14px 20px; display: flex; align-items: center; justify-content: space-between;
    }
    .card-header-title {
        font-family: 'Playfair Display', serif; font-size: 15px; font-weight: 600;
        color: var(--text-dark); margin: 0; display: flex; align-items: center; gap: 8px;
    }
    .card-header-title i { color: var(--gold); }
    .card-body { padding: 20px 24px; }
    .card-footer-light { background: var(--cream-dark); border-top: 1px solid var(--border); padding: 12px 20px; font-size: 12.5px; color: var(--text-light); }

    /* ── MAP ── */
    #map {
        height: 480px; border-radius: 0; width: 100%;
    }
    .leaflet-container { border-radius: 0; }

    /* ── FORM ── */
    .form-label { font-size: 13px; font-weight: 600; color: var(--text-dark); margin-bottom: 5px; display: block; }
    .form-control, .form-select {
        width: 100%; border: 1px solid var(--border); border-radius: var(--radius-sm);
        padding: 9px 13px; font-size: 14px; color: var(--text-dark);
        background: #fff; transition: all 0.2s ease; outline: none;
    }
    .form-control:focus, .form-select:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(184,150,78,0.12); }
    .form-control:disabled, .form-select:disabled, .form-control[readonly] { background: var(--cream); color: var(--text-light); }
    .input-group { display: flex; }
    .input-group .form-control { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
    .input-group-text {
        background: var(--cream-dark); border: 1px solid var(--border); border-right: none;
        border-radius: var(--radius-sm) 0 0 var(--radius-sm);
        padding: 9px 12px; color: var(--text-light); font-size: 14px;
        display: flex; align-items: center;
    }
    .input-group .input-group-text + .form-control { border-left: none; }
    textarea.form-control { resize: vertical; }
    .form-check { display: flex; align-items: center; gap: 8px; }
    .form-check-input { width: 16px; height: 16px; border: 1.5px solid var(--border); border-radius: 3px; cursor: pointer; accent-color: var(--gold); }
    .form-check-label { font-size: 13.5px; color: var(--text-mid); cursor: pointer; }
    .field-mb { margin-bottom: 16px; }

    /* ── COORDINATE DISPLAY ── */
    .coordinate-display {
        background: var(--cream); border: 1px solid var(--border);
        border-radius: var(--radius-sm); padding: 10px 14px;
        font-family: 'Courier New', monospace; font-size: 13px; color: var(--text-mid);
        margin-bottom: 4px;
    }

    /* ── FORM SECTION DIVIDER ── */
    .form-section-label {
        font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
        color: rgba(184,150,78,0.8); margin-bottom: 12px; margin-top: 4px;
        padding-bottom: 6px; border-bottom: 1px solid var(--border);
    }

    /* ── BUTTONS ── */
    .btn-gold {
        background: linear-gradient(135deg, var(--gold), var(--gold-light));
        color: var(--navy); border: none; font-weight: 600; font-size: 13.5px; padding: 11px 24px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        box-shadow: 0 2px 10px rgba(184,150,78,0.3);
        display: inline-flex; align-items: center; gap: 8px; cursor: pointer; width: 100%; justify-content: center;
    }
    .btn-gold:hover { color: var(--navy); box-shadow: 0 4px 16px rgba(184,150,78,0.4); transform: translateY(-1px); }
    .btn-gold:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
    .btn-secondary-custom {
        background: var(--ivory); color: var(--text-dark);
        border: 1.5px solid var(--border); font-weight: 500; font-size: 13.5px; padding: 11px 24px;
        border-radius: var(--radius-sm); transition: all 0.2s ease;
        display: inline-flex; align-items: center; gap: 8px; text-decoration: none; cursor: pointer;
        width: 100%; justify-content: center;
    }
    .btn-secondary-custom:hover { background: var(--cream); border-color: var(--gold); color: var(--text-dark); }
    .btn-current-loc {
        background: rgba(247,243,237,0.15); color: var(--cream);
        border: 1px solid rgba(247,243,237,0.3); font-size: 12.5px; font-weight: 500;
        padding: 6px 14px; border-radius: var(--radius-sm); cursor: pointer;
        transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-current-loc:hover { background: rgba(247,243,237,0.25); }

    /* ── FORM CARD HEADER ── */
    .form-card-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        padding: 16px 20px; display: flex; align-items: center; gap: 10px;
    }
    .form-card-header-title {
        font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 600;
        color: var(--cream); margin: 0; display: flex; align-items: center; gap: 8px;
    }
    .form-card-header-title i { color: var(--gold-light); }

    /* ── ANIMATIONS ── */
    @@keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.45s ease 0.08s both; }
    .anim-2 { animation: fadeUp 0.45s ease 0.15s both; }

    @@media (max-width: 576px) {
        .page-header { padding: 24px 20px; }
        .page-header-title { font-size: 1.5rem; }
        #map { height: 320px; }
    }
</style>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="StallLocation" asp-action="Index">Stall Locations</a></li>
        <li class="breadcrumb-item active" aria-current="page">@modeLabel</li>
    </ol>
</nav>

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-content">
        <h1 class="page-header-title">
            <i class="bi bi-geo-alt" aria-hidden="true"></i>@modeLabel
        </h1>
        <p class="page-header-lead">
            @if (mode == "create") { <text>Pin a location on the map and set the geofence radius.</text> }
            else if (mode == "edit") { <text>Update the stall's GPS coordinates and geofence.</text> }
            else { <text>View the stall's current location and geofence zone.</text> }
        </p>
    </div>
    <div class="page-header-actions">
        <a asp-controller="StallLocation" asp-action="Index" class="btn-ghost-cream">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>Back to List
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(ViewBag.SuccessMessage as string))
{
    <div class="alert-success-custom">
        <i class="bi bi-check-circle-fill"></i>@ViewBag.SuccessMessage
    </div>
}
@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert-error-custom">
        <i class="bi bi-exclamation-circle-fill"></i>@ViewBag.ErrorMessage
    </div>
}

<!-- Map + Form -->
<div class="row g-4">
    <!-- Map -->
    <div class="col-lg-8">
        <div class="card anim-1">
            <div class="card-header-nav">
                <h2 class="card-header-title">
                    <i class="bi bi-map" aria-hidden="true"></i>
                    OpenStreetMap
                </h2>
                @if (mode != "view")
                {
                    <button type="button" class="btn-current-loc" id="useCurrentLocationBtn">
                        <i class="bi bi-crosshair" aria-hidden="true"></i>Use My Location
                    </button>
                }
            </div>
            <div id="map"></div>
            <div class="card-footer-light">
                <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                @if (mode != "view")
                {
                    <text>Click on the map to pin a location, or drag the marker to adjust.</text>
                }
                else
                {
                    <text>Showing current stall location and geofence radius.</text>
                }
            </div>
        </div>
    </div>

    <!-- Form -->
    <div class="col-lg-4">
        <div class="card anim-2">
            <div class="form-card-header">
                <h2 class="form-card-header-title">
                    <i class="bi bi-pin-map" aria-hidden="true"></i>Location Details
                </h2>
            </div>
            <div class="card-body">
                <form id="locationForm" novalidate>

                    @if (mode == "edit" && locationId.HasValue)
                    {
                        <input type="hidden" name="id" value="@locationId.Value" />
                    }

                    <!-- Stall -->
                    <div class="field-mb">
                        <div class="form-section-label">Stall</div>
                        <label for="stallSelect" class="form-label">Select Stall <span style="color:#a2493a">*</span></label>
                        <select class="form-select" id="stallSelect" name="stallId" required
                                @(mode == "view" ? "disabled" : "")>
                            <option value="">— Select stall —</option>
                            @foreach (var s in ViewBag.Stalls as IEnumerable<Shared.DTOs.Stalls.StallDetailDto> ?? Array.Empty<Shared.DTOs.Stalls.StallDetailDto>())
                            {
                                <option value="@s.Id" selected="@(stallId == s.Id)">@s.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Coordinates -->
                    <div class="field-mb">
                        <div class="form-section-label">Coordinates</div>
                        <div class="coordinate-display" id="coordinateDisplay">
                            <i class="bi bi-crosshair me-2" aria-hidden="true"></i>
                            @if (!string.IsNullOrEmpty(latStr) && !string.IsNullOrEmpty(lngStr))
                            {
                                <text>Lat: @latStr, Lng: @lngStr</text>
                            }
                            else
                            {
                                <text>Click the map to select a location</text>
                            }
                        </div>
                    </div>

                    <!-- Latitude -->
                    <div class="field-mb">
                        <label for="latitude" class="form-label">Latitude <span style="color:#a2493a">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-compass"></i></span>
                            <input type="number" step="0.000001" min="-90" max="90"
                                   class="form-control" id="latitude" name="latitude"
                                   placeholder="0.000000" value="@latStr"
                                   @(mode == "view" ? "readonly" : "") required />
                        </div>
                    </div>

                    <!-- Longitude -->
                    <div class="field-mb">
                        <label for="longitude" class="form-label">Longitude <span style="color:#a2493a">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-compass"></i></span>
                            <input type="number" step="0.000001" min="-180" max="180"
                                   class="form-control" id="longitude" name="longitude"
                                   placeholder="0.000000" value="@lngStr"
                                   @(mode == "view" ? "readonly" : "") required />
                        </div>
                    </div>

                    <!-- Radius -->
                    <div class="field-mb">
                        <div class="form-section-label">Geofence</div>
                        <label for="radiusMeters" class="form-label">Radius (meters) <span style="color:#a2493a">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-circle"></i></span>
                            <input type="number" class="form-control" id="radiusMeters" name="radiusMeters"
                                   placeholder="100" min="10" max="5000" value="@radiusStr"
                                   @(mode == "view" ? "readonly" : "") required />
                            <span class="input-group-text">m</span>
                        </div>
                        <div style="font-size:11.5px;color:var(--text-light);margin-top:4px">Range: 10 – 5000 meters</div>
                    </div>

                    <!-- Address -->
                    <div class="field-mb">
                        <label for="address" class="form-label">Address</label>
                        <textarea class="form-control" id="address" name="address" rows="2"
                                  placeholder="Enter address" @(mode == "view" ? "readonly" : "")>@(ViewBag.Address ?? "")</textarea>
                    </div>

                    <!-- IsActive -->
                    <div class="field-mb">
                        <label class="form-check">
                            <input class="form-check-input" type="checkbox" id="isActive"
                                   name="isActive" value="true"
                                   @((ViewBag.IsActive as bool? ?? true) ? "checked" : "")
                                   @(mode == "view" ? "disabled" : "") />
                            <span class="form-check-label">Active</span>
                        </label>
                    </div>

                    <!-- Actions -->
                    <div style="display:flex;flex-direction:column;gap:10px;margin-top:20px">
                        @if (mode != "view")
                        {
                            <button type="submit" class="btn-gold" id="submitBtn">
                                <i class="bi bi-check-circle" aria-hidden="true"></i>
                                @(mode == "create" ? "Create Location" : "Save Changes")
                            </button>
                        }
                        <a asp-controller="StallLocation" asp-action="Index" class="btn-secondary-custom">
                            <i class="bi bi-arrow-left" aria-hidden="true"></i>
                            @(mode != "view" ? "Cancel" : "Back to List")
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
    // ── MAP INIT ──
    var map = L.map('map').setView([10.777451, 106.711203], 15);
    var marker = null;
    var circle = null;
    var currentLocationId = '@(locationId?.ToString() ?? "")';
    var allStallLocations = @Html.Raw(ViewBag.AllLocationsJson ?? "[]"); // safe: pre-serialized by JsonSerializer (encodes < > & by default)
    var otherMarkers = [];

    var selectedIcon = L.divIcon({
        html: '<i class="bi bi-geo-alt-fill" style="font-size:28px;color:#4a7c59;filter:drop-shadow(0 1px 3px rgba(0,0,0,.5));"></i>',
        className: '',
        iconSize: [28, 28],
        iconAnchor: [14, 28]
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19
    }).addTo(map);

    // ── OTHER STALL MARKERS ──
    function renderOtherMarkers(selectedStallId) {
        otherMarkers.forEach(function(m) { map.removeLayer(m); });
        otherMarkers = [];
        allStallLocations.forEach(function(loc) {
            if (loc.stallId === selectedStallId) return;
            var lat = parseFloat(loc.latitude);
            var lng = parseFloat(loc.longitude);
            var m = L.circleMarker([lat, lng], {
                color: '#a2493a', fillColor: '#a2493a', fillOpacity: 0.75, radius: 7, weight: 2
            }).addTo(map);
            m.bindTooltip(loc.stallName || loc.stallId, { permanent: false, direction: 'top' });
            otherMarkers.push(m);
            var c = L.circle([lat, lng], {
                color: '#a2493a', fillColor: '#a2493a', fillOpacity: 0.08,
                radius: parseFloat(loc.radiusMeters) || 8, weight: 1.5
            }).addTo(map);
            otherMarkers.push(c);
        });
    }

    // ── UPDATE LOCATION ──
    function updateLocation(lat, lng, silent) {
        $('#latitude').val(lat.toFixed(6));
        $('#longitude').val(lng.toFixed(6));
        $('#coordinateDisplay').html(
            '<i class="bi bi-geo-alt-fill me-2" style="color:#a2493a"></i>' +
            'Lat: ' + lat.toFixed(6) + ', Lng: ' + lng.toFixed(6)
        );

        if (marker) map.removeLayer(marker);
        if (circle) map.removeLayer(circle);

        marker = L.marker([lat, lng], {
            draggable: '@mode' !== 'view',
            title: 'Drag to adjust location',
            icon: selectedIcon
        }).addTo(map);

        var radius = parseFloat($('#radiusMeters').val()) || 8;
        circle = L.circle([lat, lng], {
            color: '#4a7c59', fillColor: '#4a7c59', fillOpacity: 0.15, radius: radius, weight: 2
        }).addTo(map);

        marker.on('dragend', function() {
            var pos = marker.getLatLng();
            updateLocation(pos.lat, pos.lng, false);
        });

        map.setView([lat, lng], map.getZoom());

        if (!silent) {
            showToast('Location selected!', 'success');
        }
    }

    // ── MAP CLICK ──
    @if (mode != "view")
    {
        <text>
        map.on('click', function(e) {
            updateLocation(e.latlng.lat, e.latlng.lng, false);
        });
        </text>
    }

    // ── RADIUS CHANGE ──
    $('#radiusMeters').on('input', function() {
        if (marker && circle) {
            map.removeLayer(circle);
            var pos = marker.getLatLng();
            circle = L.circle([pos.lat, pos.lng], {
                color: '#4a7c59', fillColor: '#4a7c59', fillOpacity: 0.15,
                radius: parseFloat($(this).val()) || 8, weight: 2
            }).addTo(map);
        }
    });

    // ── CURRENT LOCATION ──
    $('#useCurrentLocationBtn').on('click', function() {
        var btn = $(this);
        btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Locating...');
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function(pos) {
                updateLocation(pos.coords.latitude, pos.coords.longitude, false);
                btn.prop('disabled', false).html('<i class="bi bi-crosshair me-1"></i>Use My Location');
            }, function(err) {
                showToast('Cannot get location: ' + err.message, 'warning');
                btn.prop('disabled', false).html('<i class="bi bi-crosshair me-1"></i>Use My Location');
            });
        } else {
            showToast('Geolocation not supported by this browser.', 'warning');
            btn.prop('disabled', false).html('<i class="bi bi-crosshair me-1"></i>Use My Location');
        }
    });

    // ── STALL DROPDOWN CHANGE ──
    $('#stallSelect').on('change', function() {
        var selectedStallId = $(this).val();
        if (!selectedStallId) { currentLocationId = ''; return; }

        var jwtToken = localStorage.getItem('jwtToken');
        var base = '@apiBaseUrl'.replace(/\/$/, '');
        fetch(base + '/api/stall-location?stallId=' + selectedStallId + '&pageSize=1', {
            headers: jwtToken ? { 'Authorization': 'Bearer ' + jwtToken } : {}
        })
        .then(function(r) { return r.json(); })
        .then(function(result) {
            renderOtherMarkers(selectedStallId);
            if (result.success && result.data && result.data.items && result.data.items.length > 0) {
                var loc = result.data.items[0];
                currentLocationId = loc.id;
                $('#radiusMeters').val(loc.radiusMeters);
                $('#address').val(loc.address || '');
                $('#isActive').prop('checked', loc.isActive);
                updateLocation(parseFloat(loc.latitude), parseFloat(loc.longitude), true);
                showToast('Existing location loaded.', 'info');
            } else {
                currentLocationId = '';
                if (marker) { map.removeLayer(marker); marker = null; }
                if (circle) { map.removeLayer(circle); circle = null; }
                $('#latitude').val('');
                $('#longitude').val('');
                $('#coordinateDisplay').html('<i class="bi bi-crosshair me-2"></i>Click the map to select a location');
            }
        })
        .catch(function() { currentLocationId = ''; });
    });

    // ── FORM SUBMIT ──
    $('#locationForm').on('submit', function(e) {
        e.preventDefault();

        var lat = $('#latitude').val();
        var lng = $('#longitude').val();
        var stallIdVal = $('#stallSelect').val();

        if (!lat || !lng) {
            showToast('Please select a location on the map.', 'warning');
            return false;
        }
        if (!stallIdVal) {
            showToast('Please select a stall.', 'warning');
            return false;
        }

        var data = {
            stallId: stallIdVal,
            latitude: parseFloat(lat),
            longitude: parseFloat(lng),
            radiusMeters: parseInt($('#radiusMeters').val()) || 8,
            address: $('#address').val() || '',
            isActive: $('#isActive').is(':checked')
        };

        var jwtToken = localStorage.getItem('jwtToken');
        if (!jwtToken) {
            showToast('Please sign in again.', 'warning');
            return false;
        }

        var submitBtn = $('#submitBtn');
        submitBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Saving...');

        var base = '@apiBaseUrl'.replace(/\/$/, '');
        var url = currentLocationId ? base + '/api/stall-location/' + currentLocationId : base + '/api/stall-location';
        var method = currentLocationId ? 'PUT' : 'POST';

        fetch(url, {
            method: method,
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwtToken },
            credentials: 'same-origin',
            body: JSON.stringify(data)
        })
        .then(function(response) {
            if (!response.ok) {
                return response.text().then(function(text) {
                    try { throw new Error(JSON.parse(text).message || 'Server error: ' + response.status); }
                    catch(e) { throw new Error('Error ' + response.status + ': ' + response.statusText); }
                });
            }
            return response.json();
        })
        .then(function() {
            showToast('Saved successfully!', 'success');
            setTimeout(function() {
                window.location.href = '@Url.Action("Index", "StallLocation")';
            }, 1500);
        })
        .catch(function(err) {
            submitBtn.prop('disabled', false).html(
                '<i class="bi bi-check-circle me-1"></i>' +
                ('@mode' === 'create' ? 'Create Location' : 'Save Changes')
            );
            showToast(err.message || 'Error saving data.', 'warning');
        });
    });

    // ── TOAST ──
    function showToast(message, type) {
        var colors = { success: '#4a7c59', warning: '#b8964e', info: '#3d7a8a', error: '#a2493a' };
        var color = colors[type] || colors.info;
        var icons = { success: 'bi-check-circle', warning: 'bi-exclamation-triangle', info: 'bi-info-circle', error: 'bi-x-circle' };
        var icon = icons[type] || icons.info;
        var toast = $('<div style="position:fixed;bottom:24px;right:24px;z-index:9999">' +
            '<div style="background:' + color + ';color:#fff;padding:12px 18px;border-radius:8px;display:flex;align-items:center;gap:10px;font-size:14px;box-shadow:0 4px 16px rgba(0,0,0,0.2)">' +
            '<i class="bi ' + icon + '"></i>' + message + '</div></div>');
        $('body').append(toast);
        setTimeout(function() { toast.fadeOut(300, function() { $(this).remove(); }); }, 3000);
    }

    // ── INIT ──
    $(document).ready(function() {
        var initialStallId = '@(stallId?.ToString() ?? "")';
        renderOtherMarkers(initialStallId);

        var lat = $('#latitude').val();
        var lng = $('#longitude').val();
        if (lat && lng) {
            updateLocation(parseFloat(lat), parseFloat(lng), true);
        }
    });
</script>
}
